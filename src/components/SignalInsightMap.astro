---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const lanes = insight.lanes.slice(0, 4);

function signalBand(importance: number) {
  if (importance >= 90) return { className: 'signal-band-90', label: 'Prime' };
  if (importance >= 85) return { className: 'signal-band-85', label: 'Strong' };
  if (importance >= 80) return { className: 'signal-band-80', label: 'High' };
  if (importance >= 75) return { className: 'signal-band-75', label: 'Active' };
  if (importance >= 70) return { className: 'signal-band-70', label: 'Emerging' };
  if (importance >= 65) return { className: 'signal-band-65', label: 'Watch' };
  if (importance >= 60) return { className: 'signal-band-60', label: 'Quiet' };
  return { className: 'signal-band-55', label: 'Background' };
}

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 76 - index * 6));
  const band = signalBand(importance);
  const duration = Math.max(4.2, 9.6 - importance / 18).toFixed(1);

  return {
    ...lane,
    importance,
    duration,
    delay: (index * -1.25).toFixed(1),
    priorityLabel: band.label,
    bandClass: band.className,
  };
});

function pickLane(matchers: string[], fallbackIndex: number) {
  return signalRows.find((lane) =>
    matchers.some((matcher) => lane.label.toLowerCase().includes(matcher))
  ) ?? signalRows[fallbackIndex] ?? signalRows[0];
}

function compactState(value?: string) {
  if (!value) return 'A visible pressure point in this week\'s brief.';
  return value.length > 88 ? `${value.slice(0, 85).trim()}...` : value;
}

const schoolLane = pickLane(['education', 'learning', 'student', 'school'], 0);
const trustLane = pickLane(['trust', 'founder', 'customer', 'proof'], 2);
const workLane = pickLane(['work', 'organization', 'team', 'role'], 1);
const techLane = pickLane(['technology', 'tech', 'ai', 'tool', 'system'], signalRows.length - 1);

const sourceRows = [
  {
    key: 'school',
    label: 'School',
    lane: schoolLane,
    tone: 'source-indigo',
    pathClass: 'route-school',
    packetClass: 'packet-indigo',
    path: 'M20 82 C122 72 204 122 278 190',
  },
  {
    key: 'trust',
    label: /trust/i.test(insight.primaryTheme) ? 'Trust' : insight.primaryTheme,
    lane: trustLane,
    tone: 'source-azure',
    pathClass: 'route-trust',
    packetClass: 'packet-azure',
    path: 'M20 164 C126 148 206 168 282 204',
  },
  {
    key: 'work',
    label: 'Work',
    lane: workLane,
    tone: 'source-violet',
    pathClass: 'route-work',
    packetClass: 'packet-violet',
    path: 'M20 258 C118 274 204 254 282 222',
  },
  {
    key: 'tech',
    label: 'Tech',
    lane: techLane,
    tone: 'source-gold',
    pathClass: 'route-tech',
    packetClass: 'packet-gold',
    path: 'M20 340 C116 360 200 304 278 238',
  },
];

const conceptPositions = [
  { x: 50, y: 11 },
  { x: 77, y: 25 },
  { x: 83, y: 53 },
  { x: 64, y: 82 },
  { x: 36, y: 82 },
  { x: 17, y: 53 },
  { x: 23, y: 25 },
];

const conceptPalette: Record<string, { accent: string; soft: string; deep: string }> = {
  service: { accent: '#5B8CFF', soft: '#DCE6FF', deep: '#2E5BD0' },
  leadership: { accent: '#6E74F0', soft: '#E7E9FF', deep: '#3840BD' },
  learning: { accent: '#A06CF0', soft: '#F0E6FF', deep: '#6C36C2' },
  work: { accent: '#C9A35E', soft: '#FFF1C9', deep: '#8C6526' },
  technology: { accent: '#5B8CFF', soft: '#DCE6FF', deep: '#2E5BD0' },
};

function paletteFor(type: string) {
  return conceptPalette[type.toLowerCase()] ?? conceptPalette.service;
}

function conceptPath(xPercent: number, yPercent: number, index: number) {
  const x = Math.round(xPercent * 6);
  const y = Math.round(yPercent * 4.2);
  const controlX = Math.round((300 + x) / 2 + (index % 2 === 0 ? 22 : -22));
  const controlY = Math.round((210 + y) / 2 + (index < 3 ? -20 : 24));
  return `M300 210 Q${controlX} ${controlY} ${x} ${y}`;
}

const conceptNodes = insight.concepts.slice(0, 7).map((concept, index) => {
  const position = conceptPositions[index] ?? conceptPositions[0];
  const palette = paletteFor(concept.type);

  return {
    ...concept,
    ...position,
    palette,
    delay: `${index * 0.24}s`,
    line: conceptPath(position.x, position.y, index),
  };
});

const outputPath = 'M324 210 C404 202 498 204 580 210';
const quadrantFrames = [
  {
    title: 'High importance',
    timing: 'Useful now',
    x: 48,
    y: 54,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 128,
  },
  {
    title: 'High importance',
    timing: 'Useful later',
    x: 312,
    y: 54,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 128,
  },
  {
    title: 'Lower importance',
    timing: 'Useful now',
    x: 48,
    y: 228,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 300,
  },
  {
    title: 'Lower importance',
    timing: 'Useful later',
    x: 312,
    y: 228,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 300,
  },
];
const quadrantSignals = signalRows.slice(0, 4).map((lane, index) => ({
  ...lane,
  ...quadrantFrames[index % quadrantFrames.length],
}));
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <div>
      <p class="signal-map-label">Latest Signals Brief</p>
      <h2 id="latest-signal-map">Signal Map</h2>
    </div>
    <p class="signal-map-intro">A live reading of the week: source pressure enters, judgment translates it, and the brief leaves one path worth acting on.</p>
    <a href={`/${entry.slug}/`}>Read the full story</a>
  </div>

  <div class="signal-engine" aria-label={`Signal map for ${entry.data.title}`}>
    <div class="source-column" aria-label="Weekly signal sources">
      {sourceRows.map((row) => (
        <article
          class={`source-card ${row.tone} ${row.lane.bandClass}`}
          style={`--score:${row.lane.importance}%; --delay:${row.lane.delay}s;`}
        >
          <div class="source-card-head">
            <span>{row.label}</span>
            <em>{row.lane.importance}</em>
          </div>
          <div class="source-card-body">
            <strong>{row.lane.level}</strong>
            <p>{compactState(row.lane.state)}</p>
          </div>
          <i aria-hidden="true"><b></b></i>
        </article>
      ))}
    </div>

    <div class="signal-theater">
      <svg class="signal-stage-art" viewBox="0 0 600 420" role="img">
        <title>{`Signal translation map for ${entry.data.title}`}</title>
        <desc>{insight.signal}</desc>
        <defs>
          <linearGradient id="route-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#9DB8FF" stop-opacity=".2" />
            <stop offset="52%" stop-color="#5B8CFF" stop-opacity=".9" />
            <stop offset="100%" stop-color="#2E5BD0" stop-opacity=".28" />
          </linearGradient>
          <radialGradient id="core-fill" cx="50%" cy="50%" r="62%">
            <stop offset="0%" stop-color="#FFFFFF" />
            <stop offset="58%" stop-color="#E5ECFF" />
            <stop offset="100%" stop-color="#9DB8FF" stop-opacity=".18" />
          </radialGradient>
          <filter id="map-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feColorMatrix in="blur" type="matrix" values="0 0 0 0 0.36 0 0 0 0 0.55 0 0 0 0 1 0 0 0 .58 0" />
            <feMerge>
              <feMergeNode />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <rect class="stage-frame" x="12" y="12" width="576" height="396" rx="24" />
        <path class="stage-grid" d="M48 66H552M48 126H552M48 186H552M48 246H552M48 306H552M48 366H552M96 42V378M168 42V378M240 42V378M312 42V378M384 42V378M456 42V378M528 42V378" />
        <path class="stage-scan" d="M86 368 L514 50" />
        <g class="priority-quadrants" aria-hidden="true">
          {quadrantFrames.map((quadrant, index) => (
            <g class={`priority-cell priority-cell-${index + 1}`}>
              <rect
                x={quadrant.x}
                y={quadrant.y}
                width={quadrant.width}
                height={quadrant.height}
                rx="16"
              />
              <text class="priority-title" x={quadrant.x + 16} y={quadrant.y + 25}>{quadrant.title}</text>
              <text class="priority-time" x={quadrant.x + 16} y={quadrant.y + 48}>{quadrant.timing}</text>
            </g>
          ))}
          <path class="priority-axis" d="M300 54V366M48 210H552" />
          <text class="priority-axis-label priority-axis-importance" x="34" y="202" transform="rotate(-90 34 202)">Importance</text>
          <text class="priority-axis-label priority-axis-usefulness" x="448" y="388">Usefulness</text>
          {quadrantSignals.map((signal, index) => (
            <g class="priority-signal" style={`--priority-delay:${index * 0.16}s;`}>
              <circle cx={signal.pointX} cy={signal.pointY} r="17" />
              <circle class="priority-signal-core" cx={signal.pointX} cy={signal.pointY} r="6" />
              <text x={signal.pointX} y={signal.pointY - 25}>{signal.label}</text>
              <text class="priority-signal-level" x={signal.pointX} y={signal.pointY + 34}>{signal.level}</text>
            </g>
          ))}
        </g>

        {sourceRows.map((row) => (
          <>
            <path class={`signal-route-under ${row.pathClass}`} d={row.path} />
            <path class={`signal-route ${row.pathClass}`} d={row.path} style={`--route-weight:${row.lane.importance};`} />
            <g class={`signal-courier ${row.packetClass}`} filter="url(#map-glow)">
              <path d="M0 -9 L9 0 L0 9 L-9 0Z" />
              <path class="courier-tail" d="M-26 0H-9" />
              <animateMotion dur={`${row.lane.duration}s`} begin={`${row.lane.delay}s`} repeatCount="indefinite" path={row.path} rotate="auto" />
            </g>
          </>
        ))}

        {conceptNodes.map((node) => (
          <path
            class="concept-line"
            d={node.line}
            style={`--accent:${node.palette.accent}; --delay:${node.delay};`}
          />
        ))}

        <path class="output-route-under" d={outputPath} />
        <path class="output-route" d={outputPath} />
        <g class="output-courier" filter="url(#map-glow)">
          <rect x="-14" y="-6" width="28" height="12" rx="6" />
          <path d="M17 0H43" />
          <animateMotion dur="4.7s" repeatCount="indefinite" path={outputPath} rotate="auto" />
        </g>

        <g class="core-orbit">
          <circle cx="300" cy="210" r="92" />
          <circle cx="300" cy="210" r="66" />
          <circle cx="300" cy="210" r="38" />
        </g>
        <g class="core-mark" filter="url(#map-glow)">
          <circle cx="300" cy="210" r="58" />
          <path d="M300 132 370 210 300 288 230 210Z" />
          <path d="M300 173 334 210 300 247 266 210Z" />
        </g>
      </svg>

      {conceptNodes.map((node) => (
        <span
          class="concept-node"
          style={`--x:${node.x}%; --y:${node.y}%; --accent:${node.palette.accent}; --soft:${node.palette.soft}; --deep:${node.palette.deep}; --delay:${node.delay};`}
        >
          {node.label}
        </span>
      ))}

      <div class="core-caption">
        <span>Translation Core</span>
      </div>
    </div>

    <article class="action-column">
      <span class="action-kicker">Action Path</span>
      <strong>{insight.signal}</strong>
      <p>{insight.micro}</p>
      <div class="action-sequence" aria-hidden="true">
        <span>Read</span>
        <i></i>
        <span>Translate</span>
        <i></i>
        <span>Act</span>
      </div>
    </article>
  </div>

  <div class="signal-footer-line">
    <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
    <p>Same system every week, new signal each issue.</p>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    gap: clamp(16px, 3vw, 24px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background:
      radial-gradient(circle at 74% 20%, rgba(91, 140, 255, .18), transparent 23rem),
      radial-gradient(circle at 24% 76%, rgba(160, 108, 240, .1), transparent 20rem),
      linear-gradient(135deg, rgba(255, 255, 255, .96), rgba(240, 245, 255, .9));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .11);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-engine,
  .signal-footer-line {
    position: relative;
    z-index: 1;
  }

  .signal-map-copy {
    display: grid;
    grid-template-columns: minmax(190px, .42fr) minmax(320px, 1fr) auto;
    align-items: end;
    gap: clamp(14px, 2vw, 22px);
  }

  .signal-map-label,
  .signal-map-copy a,
  .source-card-head,
  .source-card-body strong,
  .concept-node,
  .core-caption span,
  .action-kicker,
  .action-sequence,
  .signal-footer-line {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 3rem);
    line-height: .95;
  }

  .signal-map-intro {
    max-width: 60ch;
    margin: 0;
    color: #4f5d78;
    font-size: .95rem;
    line-height: 1.45;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .72);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
    white-space: nowrap;
  }

  .signal-engine {
    display: grid;
    grid-template-columns: minmax(190px, .82fr) minmax(430px, 1.46fr) minmax(230px, .9fr);
    gap: clamp(14px, 2.2vw, 24px);
    align-items: stretch;
  }

  .source-column {
    display: grid;
    gap: 10px;
    align-content: center;
  }

  .source-card {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    position: relative;
    display: grid;
    gap: .44rem;
    min-height: 96px;
    padding: .74rem .78rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .16);
    border-radius: 14px;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--signal-soft) 26%, transparent), transparent 42%),
      rgba(255, 255, 255, .84);
    box-shadow: 0 14px 28px rgba(46, 91, 208, .08);
    backdrop-filter: blur(10px);
    animation: sourceWake 5.8s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .source-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
  }

  .source-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 0 38%, rgba(255, 255, 255, .5) 48%, transparent 58% 100%);
    transform: translateX(-130%);
    animation: cardScan 6.6s ease-in-out infinite;
    animation-delay: calc(var(--delay) + .4s);
  }

  .source-indigo { --signal-accent: var(--indigo); --signal-soft: var(--indigo-soft); --signal-deep: var(--indigo-deep); }
  .source-azure { --signal-accent: var(--azure); --signal-soft: var(--azure-soft); --signal-deep: var(--azure-deep); }
  .source-violet { --signal-accent: var(--violet); --signal-soft: var(--violet-soft); --signal-deep: var(--violet-deep); }
  .source-gold { --signal-accent: var(--gold); --signal-soft: var(--gold-soft); --signal-deep: var(--gold-deep); }

  .source-card-head,
  .source-card-body,
  .source-card i {
    position: relative;
    z-index: 1;
  }

  .source-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    color: var(--signal-deep);
    font-size: .62rem;
    letter-spacing: .13em;
  }

  .source-card-head em {
    display: inline-grid;
    place-items: center;
    min-width: 2.1rem;
    min-height: 1.3rem;
    border: 1px solid color-mix(in srgb, var(--signal-accent) 34%, transparent);
    border-radius: 999px;
    color: var(--ink);
    font-style: normal;
    background: rgba(255, 255, 255, .58);
  }

  .source-card-body {
    display: grid;
    gap: .18rem;
  }

  .source-card-body strong {
    color: var(--ink);
    font-size: .73rem;
    letter-spacing: .08em;
  }

  .source-card-body p {
    margin: 0;
    color: #4d5a74;
    font-size: .78rem;
    line-height: 1.25;
  }

  .source-card i {
    height: 4px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .source-card b {
    display: block;
    width: var(--score);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px rgba(91, 140, 255, .36);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
  }

  .signal-theater {
    position: relative;
    min-height: 430px;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 18px;
    background:
      radial-gradient(circle at 50% 50%, rgba(91, 140, 255, .18), transparent 13rem),
      radial-gradient(circle at 32% 28%, rgba(160, 108, 240, .1), transparent 13rem),
      linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(241, 246, 255, .84));
    box-shadow: 0 18px 48px rgba(46, 91, 208, .1);
    isolation: isolate;
  }

  .signal-theater::before {
    content: "";
    position: absolute;
    inset: 21%;
    border-radius: 50%;
    background: conic-gradient(from 0deg, transparent, rgba(91, 140, 255, .2), transparent, rgba(160, 108, 240, .18), transparent);
    filter: blur(12px);
    opacity: .74;
    animation: chamberTurn 18s linear infinite;
  }

  .signal-stage-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .stage-frame {
    fill: rgba(255, 255, 255, .32);
    stroke: rgba(46, 91, 208, .14);
  }

  .stage-grid {
    fill: none;
    stroke: rgba(46, 91, 208, .065);
    stroke-width: 1;
  }

  .stage-scan {
    fill: none;
    stroke: rgba(157, 184, 255, .26);
    stroke-linecap: round;
    stroke-width: 36;
    animation: scanSweep 8s ease-in-out infinite;
  }

  .priority-quadrants {
    opacity: .94;
  }

  .priority-cell rect {
    fill: rgba(255, 255, 255, .38);
    stroke: rgba(46, 91, 208, .13);
    stroke-width: 1;
  }

  .priority-cell-1 rect {
    fill: rgba(91, 140, 255, .14);
  }

  .priority-cell-2 rect {
    fill: rgba(160, 108, 240, .11);
  }

  .priority-cell-3 rect {
    fill: rgba(201, 163, 94, .12);
  }

  .priority-cell-4 rect {
    fill: rgba(79, 182, 168, .1);
  }

  .priority-title,
  .priority-time,
  .priority-axis-label,
  .priority-signal text {
    font-family: var(--font-label);
    font-weight: 800;
    text-anchor: start;
  }

  .priority-title {
    fill: rgba(36, 49, 77, .72);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .priority-time {
    fill: rgba(46, 91, 208, .76);
    font-size: 16px;
  }

  .priority-axis {
    fill: none;
    stroke: rgba(46, 91, 208, .18);
    stroke-dasharray: 8 10;
    stroke-width: 1.4;
  }

  .priority-axis-label {
    fill: rgba(46, 91, 208, .52);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .priority-signal {
    animation: prioritySignalRise 900ms ease both;
    animation-delay: var(--priority-delay);
  }

  .priority-signal circle {
    fill: rgba(255, 255, 255, .86);
    stroke: rgba(46, 91, 208, .44);
    stroke-width: 2;
  }

  .priority-signal-core {
    fill: var(--azure-deep);
    stroke: #fff;
    stroke-width: 2;
    animation: ringPulse 3.6s ease-in-out infinite;
  }

  .priority-signal text {
    fill: #24314d;
    font-size: 12px;
    letter-spacing: .04em;
    text-anchor: middle;
  }

  .priority-signal-level {
    fill: rgba(46, 91, 208, .76);
    font-size: 9px;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .signal-route-under,
  .signal-route,
  .concept-line,
  .output-route-under,
  .output-route {
    fill: none;
    stroke-linecap: round;
  }

  .signal-route-under {
    stroke: rgba(91, 140, 255, .12);
    stroke-width: 16;
  }

