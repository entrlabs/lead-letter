---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const concepts = insight.concepts.slice(0, 4);
const lanes = insight.lanes.slice(0, 4);

function signalBand(importance: number) {
  if (importance >= 90) return { className: 'signal-band-90', label: 'Prime signal' };
  if (importance >= 85) return { className: 'signal-band-85', label: 'Strong signal' };
  if (importance >= 80) return { className: 'signal-band-80', label: 'High signal' };
  if (importance >= 75) return { className: 'signal-band-75', label: 'Active signal' };
  if (importance >= 70) return { className: 'signal-band-70', label: 'Emerging signal' };
  if (importance >= 65) return { className: 'signal-band-65', label: 'Watch signal' };
  if (importance >= 60) return { className: 'signal-band-60', label: 'Low signal' };
  return { className: 'signal-band-55', label: 'Background signal' };
}

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 72 - index * 6));
  const band = signalBand(importance);
  return {
    ...lane,
    importance,
    priorityLabel: band.label,
    bandClass: band.className,
  };
});

function pickLane(matchers: string[], fallbackIndex: number) {
  return signalRows.find((lane) =>
    matchers.some((matcher) => lane.label.toLowerCase().includes(matcher))
  ) ?? signalRows[fallbackIndex] ?? signalRows[0];
}

const schoolLane = pickLane(['education', 'learning', 'student', 'school'], 0);
const workLane = pickLane(['work', 'organization', 'team', 'role'], 1);
const techLane = pickLane(['technology', 'tech', 'ai', 'tool', 'system'], signalRows.length - 1);
const trustLabel = /trust/i.test(insight.primaryTheme) ? 'Trust' : insight.primaryTheme;

const visualNodes = [
  {
    key: 'trust',
    label: trustLabel,
    support: concepts[0]?.label ?? 'Signal',
    positionClass: 'node-top',
    toneClass: 'node-azure',
  },
  {
    key: 'school',
    label: 'School',
    support: schoolLane?.state ?? 'Learning needs translation into visible proof.',
    positionClass: 'node-left',
    toneClass: 'node-indigo',
  },
  {
    key: 'work',
    label: 'Work',
    support: workLane?.state ?? 'Work needs translation into reliable practice.',
    positionClass: 'node-right',
    toneClass: 'node-violet',
  },
  {
    key: 'tech',
    label: 'Tech',
    support: techLane?.state ?? 'Technology needs translation into judgment.',
    positionClass: 'node-bottom',
    toneClass: 'node-gold',
  },
];
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <div>
      <p class="signal-map-label">Latest Signals Brief</p>
      <h2 id="latest-signal-map">Signal Map</h2>
    </div>
    <p class="signal-map-intro">A live visual read of the newest brief: where pressure is building, what it is touching, and what needs translation into action.</p>
    <a href={`/${entry.slug}/`}>Read the full story</a>
  </div>

  <div class="signal-map-stage">
    <div class="signal-map-canvas" aria-label={`Signal field for ${entry.data.title}`}>
      <svg viewBox="0 0 1200 420" role="img">
        <title>{`Signal field for ${entry.data.title}`}</title>
        <desc>{insight.signal}</desc>
        <defs>
          <radialGradient id="field-glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#9DB8FF" stop-opacity=".34" />
            <stop offset="55%" stop-color="#5B8CFF" stop-opacity=".12" />
            <stop offset="100%" stop-color="#2E5BD0" stop-opacity="0" />
          </radialGradient>
          <linearGradient id="flow-line" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(91,140,255,.08)" />
            <stop offset="50%" stop-color="rgba(91,140,255,.82)" />
            <stop offset="100%" stop-color="rgba(91,140,255,.08)" />
          </linearGradient>
        </defs>

        <rect class="field-frame" x="18" y="18" width="1164" height="384" rx="24" />
        <rect class="field-grid" x="74" y="74" width="1052" height="272" rx="16" />
        <path class="field-grid-lines" d="M160 74V346M292 74V346M424 74V346M556 74V346M688 74V346M820 74V346M952 74V346M1084 74V346M74 128H1126M74 182H1126M74 236H1126M74 290H1126" />

        <circle class="field-halo" cx="600" cy="210" r="128" />
        <path class="field-connector connector-top" d="M600 210 C600 182 600 150 600 114" />
        <path class="field-connector connector-left" d="M600 210 C516 210 402 210 248 210" />
        <path class="field-connector connector-right" d="M600 210 C684 210 798 210 952 210" />
        <path class="field-connector connector-bottom" d="M600 210 C600 238 600 270 600 306" />

        <circle class="field-pulse pulse-top" cx="600" cy="114" r="10" />
        <circle class="field-pulse pulse-left" cx="248" cy="210" r="10" />
        <circle class="field-pulse pulse-right" cx="952" cy="210" r="10" />
        <circle class="field-pulse pulse-bottom" cx="600" cy="306" r="10" />

        <g class="field-core">
          <circle cx="600" cy="210" r="54" />
          <path d="M600 142 666 210 600 278 534 210Z" />
          <path d="M600 174 636 210 600 246 564 210Z" />
        </g>
      </svg>

      <div class="field-node field-node-center">
        <span class="field-node-eyebrow">Center</span>
        <strong>People</strong>
        <p>Broad signals only become useful when someone turns them into a next step.</p>
      </div>

      {visualNodes.map((node) => (
        <article class={`field-node ${node.positionClass} ${node.toneClass}`}>
          <span class="field-node-eyebrow">Signal</span>
          <strong>{node.label}</strong>
          <p>{node.support}</p>
        </article>
      ))}
    </div>

    <div class="signal-map-caption">
      <p>This week's map shows the same pressure across school, trust, work, and tech: signals need translation before they become useful.</p>
      <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
    </div>

    <div class="signal-lanes" aria-label="Current signals in this brief">
      {signalRows.map((lane, index) => (
        <article class={`signal-strip ${lane.bandClass}`} style={`--i:${index}; --importance:${lane.importance}; --importance-pct:${lane.importance}%`}>
          <div class="signal-strip-main">
            <strong>{lane.label}</strong>
            <span>{lane.level}</span>
          </div>
          <p>{lane.state}</p>
          <div class="signal-priority" aria-label={`${lane.priorityLabel}: ${lane.importance} out of 100`}>
            <span>Priority · {lane.priorityLabel}</span>
            <i><b></b></i>
            <em>{lane.importance}/100</em>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    gap: clamp(18px, 3vw, 28px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background:
      radial-gradient(circle at 76% 18%, rgba(91, 140, 255, .18), transparent 22rem),
      linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(239, 244, 255, .8));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .12);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-map-stage {
    position: relative;
    z-index: 1;
  }

  .signal-map-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, .95fr) auto;
    align-items: end;
    gap: clamp(14px, 2vw, 22px);
  }

  .signal-map-label,
  .signal-map-copy a,
  .signal-priority,
  .signal-strip-main span,
  .field-node-eyebrow,
  .signal-map-caption span {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 3rem);
    line-height: .95;
  }

  .signal-map-intro {
    margin: 0;
    color: #4f5d78;
    font-size: .95rem;
    line-height: 1.45;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .72);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
    white-space: nowrap;
  }

  .signal-map-stage {
    display: grid;
    gap: 14px;
  }

  .signal-map-canvas {
    position: relative;
    min-height: clamp(360px, 42vw, 520px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 18px;
    background:
      radial-gradient(circle at 50% 50%, rgba(91, 140, 255, .16), transparent 20rem),
      linear-gradient(180deg, rgba(255, 255, 255, .92), rgba(242, 246, 255, .84));
    box-shadow: 0 18px 48px rgba(46, 91, 208, .1);
  }

  .signal-map-canvas svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .field-frame {
    fill: rgba(255, 255, 255, .34);
    stroke: rgba(46, 91, 208, .18);
  }

  .field-grid {
    fill: rgba(255, 255, 255, .48);
    stroke: rgba(46, 91, 208, .12);
  }

  .field-grid-lines {
    fill: none;
    stroke: rgba(46, 91, 208, .08);
    stroke-width: 1;
  }

  .field-halo {
    fill: url(#field-glow);
    animation: fieldBreath 3.4s ease-in-out infinite;
  }

  .field-connector {
    fill: none;
    stroke: rgba(91, 140, 255, .56);
    stroke-width: 3.2;
    stroke-linecap: round;
    stroke-dasharray: 14 18;
    animation: connectorMove 10s linear infinite;
  }

  .connector-left,
  .connector-right {
    animation-duration: 8s;
  }

  .field-pulse {
    fill: rgba(91, 140, 255, .9);
    stroke: rgba(255, 255, 255, .9);
    stroke-width: 4;
    animation: nodePulse 2.8s ease-in-out infinite;
  }

  .pulse-left { fill: var(--indigo); }
  .pulse-right { fill: var(--violet); }
  .pulse-bottom { fill: var(--gold); }

  .field-core circle {
    fill: rgba(255, 255, 255, .86);
    stroke: rgba(46, 91, 208, .16);
  }

  .field-core path:first-of-type {
    fill: rgba(255, 255, 255, .96);
    stroke: rgba(46, 91, 208, .78);
    stroke-width: 4;
  }

  .field-core path:last-of-type {
    fill: var(--azure-deep);
    animation: coreFloat 4.4s ease-in-out infinite;
  }

  .field-node {
    position: absolute;
    display: grid;
    gap: .34rem;
    width: min(250px, 24vw);
    padding: .9rem 1rem;
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 14px;
    background: rgba(255, 255, 255, .84);
    box-shadow: 0 16px 32px rgba(46, 91, 208, .1);
    backdrop-filter: blur(10px);
  }

  .field-node-eyebrow {
    color: var(--azure-deep);
    font-size: .56rem;
    letter-spacing: .14em;
  }

  .field-node strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.8vw, 1.45rem);
    line-height: 1;
  }

  .field-node p {
    margin: 0;
    color: #4d5a74;
    font-size: .82rem;
    line-height: 1.34;
  }

  .field-node-center {
    left: 50%;
    top: 50%;
    width: min(300px, 28vw);
    transform: translate(-50%, -50%);
    text-align: center;
  }

  .field-node-center .field-node-eyebrow {
    justify-self: center;
  }

  .node-top {
    left: 50%;
    top: 8%;
    transform: translateX(-50%);
  }

  .node-left {
    left: 5%;
    top: 50%;
    transform: translateY(-50%);
  }

  .node-right {
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
  }

  .node-bottom {
    left: 50%;
    bottom: 8%;
    transform: translateX(-50%);
  }

  .node-azure { border-color: rgba(91, 140, 255, .24); }
  .node-indigo { border-color: rgba(110, 116, 240, .24); }
  .node-violet { border-color: rgba(160, 108, 240, .24); }
  .node-gold { border-color: rgba(201, 163, 94, .26); }

  .signal-map-caption {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: flex-start;
    padding: 0 4px;
  }

  .signal-map-caption p {
    max-width: 66ch;
    margin: 0;
    color: #4d5a74;
    font-size: .94rem;
    line-height: 1.42;
  }

  .signal-map-caption span {
    color: #6a7893;
    font-size: .66rem;
    letter-spacing: .14em;
    white-space: nowrap;
  }

  .signal-lanes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .signal-strip {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    --signal-wash: rgba(91, 140, 255, .13);
    --signal-glow: rgba(91, 140, 255, .46);
    position: relative;
    display: grid;
    grid-template-columns: minmax(104px, .34fr) minmax(0, 1fr) minmax(132px, .34fr);
    align-items: center;
    gap: clamp(10px, 1.6vw, 14px);
    min-height: 0;
    padding: .7rem .8rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .13);
    border-radius: 10px;
    background:
      linear-gradient(90deg, var(--signal-wash), transparent var(--importance-pct)),
      rgba(255, 255, 255, .72);
    box-shadow: 0 10px 24px rgba(46, 91, 208, .07);
    opacity: 0;
    animation: laneReveal .72s ease both;
    animation-delay: calc(var(--i) * 90ms + 180ms);
  }

  .signal-strip::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-accent), var(--signal-deep));
    opacity: .9;
  }

  .signal-strip-main {
    display: grid;
    gap: 2px;
  }

  .signal-strip-main strong {
    color: var(--ink);
    font-family: var(--font-label);
    font-size: .8rem;
    letter-spacing: .01em;
  }

  .signal-strip-main span {
    color: var(--signal-deep);
    font-size: .58rem;
    letter-spacing: .12em;
  }

  .signal-strip p {
    margin: 0;
    color: #4d5a74;
    font-size: .8rem;
    line-height: 1.22;
  }

  .signal-priority {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 5px 8px;
    color: var(--signal-deep);
    font-size: .6rem;
    letter-spacing: .1em;
  }

  .signal-priority i {
    grid-column: 1 / -1;
    position: relative;
    height: 5px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .signal-priority b {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--importance-pct);
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px var(--signal-glow);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
    animation-delay: calc(var(--i) * 90ms + 300ms);
  }

  .signal-priority em {
    color: var(--ink);
    font-style: normal;
  }

  .signal-band-90 {
    --signal-accent: #2E5BD0;
    --signal-soft: #9DB8FF;
    --signal-deep: #163C9C;
    --signal-wash: rgba(46, 91, 208, .18);
    --signal-glow: rgba(46, 91, 208, .5);
  }

  .signal-band-85 {
    --signal-accent: #5B8CFF;
    --signal-soft: #B9CAFF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(91, 140, 255, .16);
    --signal-glow: rgba(91, 140, 255, .48);
  }

  .signal-band-80 {
    --signal-accent: #6E74F0;
    --signal-soft: #A9AEFF;
    --signal-deep: #3840BD;
    --signal-wash: rgba(110, 116, 240, .15);
    --signal-glow: rgba(110, 116, 240, .44);
  }

  .signal-band-75 {
    --signal-accent: #A06CF0;
    --signal-soft: #C9A8FF;
    --signal-deep: #6C36C2;
    --signal-wash: rgba(160, 108, 240, .14);
    --signal-glow: rgba(160, 108, 240, .42);
  }

  .signal-band-70 {
    --signal-accent: #C9A35E;
    --signal-soft: #E6CB8E;
    --signal-deep: #8C6526;
    --signal-wash: rgba(201, 163, 94, .15);
    --signal-glow: rgba(201, 163, 94, .42);
  }

  .signal-band-65 {
    --signal-accent: #7FA3FF;
    --signal-soft: #C8D6FF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(127, 163, 255, .13);
    --signal-glow: rgba(127, 163, 255, .38);
  }

  .signal-band-60 {
    --signal-accent: #7F86E8;
    --signal-soft: #C8CBFF;
    --signal-deep: #4D55B5;
    --signal-wash: rgba(127, 134, 232, .12);
    --signal-glow: rgba(127, 134, 232, .34);
  }

  .signal-band-55 {
    --signal-accent: #8A97B8;
    --signal-soft: #D7DEEF;
    --signal-deep: #52617C;
    --signal-wash: rgba(138, 151, 184, .11);
    --signal-glow: rgba(138, 151, 184, .28);
  }

  @keyframes connectorMove {
    to { stroke-dashoffset: -64; }
  }

  @keyframes nodePulse {
    50% { transform: scale(1.16); filter: drop-shadow(0 0 10px rgba(91, 140, 255, .48)); }
  }

  @keyframes fieldBreath {
    50% { opacity: .76; transform: scale(1.04); transform-origin: center; }
  }

  @keyframes coreFloat {
    50% { transform: translateY(-6px); transform-origin: center; }
  }

  @keyframes laneReveal {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes priorityFill {
    from { transform: scaleX(.18); }
    to { transform: scaleX(1); }
  }

  @media (max-width: 980px) {
    .signal-map-copy {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .signal-map-copy a {
      justify-self: start;
    }

    .field-node {
      width: min(240px, 36vw);
    }
  }

  @media (max-width: 760px) {
    .signal-map-canvas {
      min-height: 700px;
    }

    .field-node {
      width: auto;
      max-width: none;
    }

    .field-node-center {
      left: 50%;
      top: 50%;
      width: min(280px, calc(100% - 28px));
    }

    .node-top {
      top: 18px;
      width: calc(100% - 28px);
    }

    .node-left,
    .node-right {
      top: auto;
      width: calc(50% - 21px);
      transform: none;
    }

    .node-left {
      left: 14px;
      bottom: 132px;
    }

    .node-right {
      right: 14px;
      bottom: 132px;
    }

    .node-bottom {
      bottom: 18px;
      width: calc(100% - 28px);
    }

    .signal-map-caption,
    .signal-lanes,
    .signal-strip {
      grid-template-columns: 1fr;
    }

    .signal-map-caption {
      display: grid;
    }

    .signal-lanes {
      grid-template-columns: 1fr;
    }

    .signal-strip {
      gap: 8px;
    }

    .signal-priority {
      grid-template-columns: auto 1fr auto;
    }

    .signal-priority i {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .field-halo,
    .field-connector,
    .field-pulse,
    .field-core path:last-of-type,
    .signal-strip,
    .signal-priority b {
      animation: none;
    }
  }
</style>
