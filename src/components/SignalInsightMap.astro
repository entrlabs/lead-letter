---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const lanes = insight.lanes.slice(0, 4);

type QuadrantKey = 'high-now' | 'high-later' | 'low-now' | 'low-later';

const controlledLabelMap: Record<string, string> = {
  school: 'Education',
  learning: 'Education',
  education: 'Education',
  technology: 'Tech',
  tech: 'Tech',
  people: 'Community',
  community: 'Community',
  money: 'Market',
  market: 'Market',
  trust: 'Society',
  society: 'Society',
};

function displayField(value?: string) {
  const cleaned = String(value ?? '').trim();
  return controlledLabelMap[cleaned.toLowerCase()] ?? cleaned;
}

function signalBand(importance: number) {
  if (importance >= 98) return { className: 'signal-band-100', label: 'Peak' };
  if (importance >= 94) return { className: 'signal-band-96', label: 'Peak' };
  if (importance >= 90) return { className: 'signal-band-92', label: 'Prime' };
  if (importance >= 86) return { className: 'signal-band-88', label: 'Prime' };
  if (importance >= 82) return { className: 'signal-band-84', label: 'Strong' };
  if (importance >= 78) return { className: 'signal-band-80', label: 'High' };
  if (importance >= 74) return { className: 'signal-band-76', label: 'Active' };
  if (importance >= 70) return { className: 'signal-band-72', label: 'Emerging' };
  if (importance >= 66) return { className: 'signal-band-68', label: 'Watch' };
  if (importance >= 62) return { className: 'signal-band-64', label: 'Watch' };
  if (importance >= 58) return { className: 'signal-band-60', label: 'Quiet' };
  return { className: 'signal-band-56', label: 'Background' };
}

function signalNumber(index: number) {
  return String(index + 1).padStart(2, '0');
}

function compactState(value?: string) {
  if (!value) return 'A visible pressure point in this week\'s brief.';
  return value.length > 88 ? `${value.slice(0, 85).trim()}...` : value;
}

const quadrantFrames = [
  {
    key: 'high-now' as QuadrantKey,
    title: 'High importance',
    timing: 'Useful now',
    shortLabel: 'High importance, useful now',
    x: 48,
    y: 54,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 128,
  },
  {
    key: 'high-later' as QuadrantKey,
    title: 'High importance',
    timing: 'Useful later',
    shortLabel: 'High importance, useful later',
    x: 312,
    y: 54,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 128,
  },
  {
    key: 'low-now' as QuadrantKey,
    title: 'Lower importance',
    timing: 'Useful now',
    shortLabel: 'Lower importance, useful now',
    x: 48,
    y: 228,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 334,
  },
  {
    key: 'low-later' as QuadrantKey,
    title: 'Lower importance',
    timing: 'Useful later',
    shortLabel: 'Lower importance, useful later',
    x: 312,
    y: 228,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 334,
  },
];

const quadrantByKey = Object.fromEntries(quadrantFrames.map((frame) => [frame.key, frame])) as Record<QuadrantKey, typeof quadrantFrames[number]>;

function laneSearchText(lane: typeof lanes[number]) {
  return [
    lane.label,
    lane.field,
    lane.level,
    lane.state,
    lane.strength,
    lane.classification,
    lane.meaning,
    lane.brief,
  ].filter(Boolean).join(' ').toLowerCase();
}

function usefulnessFor(lane: typeof lanes[number]) {
  if (typeof lane.usefulness === 'number') return Math.min(100, Math.max(0, lane.usefulness));
  if (lane.timeframe === 'now') return 78;
  if (lane.timeframe === 'later') return 34;

  const text = laneSearchText(lane);
  let score = 48;

  if (lane.direction === 'up') score += 16;
  if (lane.direction === 'down') score -= 10;
  if (lane.direction === 'steady') score -= 4;
  if (/\b(urgent|immediate|now|today|current|active|rising|action|operate|operating|decision|support|practice)\b/.test(text)) score += 18;
  if (/\b(later|future|watch|watching|emerging|monitor|next|developing|longer-term)\b/.test(text)) score -= 28;
  if (/\b(confirmed|strong|prime|leading)\b/.test(text)) score += 8;

  return Math.min(100, Math.max(0, score));
}

function quadrantKeyFor(lane: typeof lanes[number], importance: number, usefulness: number): QuadrantKey {
  if (lane.quadrant) return lane.quadrant;
  const highImportance = importance >= 82;
  const usefulNow = usefulness >= 60;

  if (highImportance && usefulNow) return 'high-now';
  if (highImportance) return 'high-later';
  if (usefulNow) return 'low-now';
  return 'low-later';
}

const quadrantSlots = [
  { dx: 0, dy: -24 },
  { dx: 0, dy: 46 },
  { dx: -62, dy: 12 },
  { dx: 62, dy: 12 },
];

const mobileQuadrantAnchors: Record<QuadrantKey, { x: number; y: number }> = {
  'high-now': { x: 26, y: 27 },
  'high-later': { x: 74, y: 27 },
  'low-now': { x: 26, y: 73 },
  'low-later': { x: 74, y: 73 },
};

const mobileQuadrantSlots = [
  { dx: -5, dy: -5 },
  { dx: 9, dy: 9 },
  { dx: -9, dy: 10 },
  { dx: 8, dy: -8 },
];

const sourceTones = ['source-indigo', 'source-azure', 'source-violet', 'source-gold'];
const quadrantUseCounts: Record<number, number> = {};

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 76 - index * 6));
  const usefulness = usefulnessFor(lane);
  const quadrantKey = quadrantKeyFor(lane, importance, usefulness);
  const band = signalBand(importance);
  const displayLabel = displayField(lane.field ?? lane.label);
  const frame = quadrantByKey[quadrantKey];
  const matrixIndex = quadrantFrames.findIndex((quadrant) => quadrant.key === quadrantKey);
  const slotIndex = quadrantUseCounts[matrixIndex] ?? 0;
  const slot = quadrantSlots[slotIndex] ?? quadrantSlots[0];
  const mobileAnchor = mobileQuadrantAnchors[quadrantKey];
  const mobileSlot = mobileQuadrantSlots[slotIndex] ?? mobileQuadrantSlots[0];
  quadrantUseCounts[matrixIndex] = (quadrantUseCounts[matrixIndex] ?? 0) + 1;

  return {
    ...lane,
    displayLabel,
    importance,
    usefulness,
    quadrantKey,
    matrixIndex,
    signalNumber: signalNumber(index),
    priorityLabel: band.label,
    bandClass: band.className,
    tone: sourceTones[index % sourceTones.length],
    delay: (index * -1.1).toFixed(1),
    pulseDelay: (index * .18).toFixed(2),
    ...frame,
    pointX: frame.pointX + slot.dx,
    pointY: frame.pointY + slot.dy,
    pointXPct: (((frame.pointX + slot.dx) / 600) * 100).toFixed(2),
    pointYPct: (((frame.pointY + slot.dy) / 420) * 100).toFixed(2),
    mobileXPct: Math.min(92, Math.max(8, mobileAnchor.x + mobileSlot.dx)).toFixed(2),
    mobileYPct: Math.min(92, Math.max(8, mobileAnchor.y + mobileSlot.dy)).toFixed(2),
    quadrantLabel: frame.shortLabel,
    timingLabel: usefulness >= 60 ? 'Useful now' : 'Useful later',
  };
});

const sourceRows = signalRows;
const quadrantSignals = signalRows.slice(0, 4);
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <div>
      <p class="signal-map-label">Latest Signals Brief</p>
      <h2 id="latest-signal-map">Signal Map</h2>
    </div>
    <p class="signal-map-intro">A live decision field for the week: each signal is placed by importance and usefulness so the next move is easier to read.</p>
    <a href={`/${entry.slug}/`}>Read the full story</a>
  </div>

  <div class="signal-engine" aria-label={`Signal map for ${entry.data.title}`}>
    <div class="source-column" aria-label="Weekly signal priority lanes">
      {sourceRows.map((row) => (
        <article
          class={`source-card ${row.tone} ${row.bandClass}`}
          style={`--score:${row.importance}%; --delay:${row.delay}s;`}
        >
          <div class="source-card-head">
            <span>Signal {row.signalNumber}</span>
            <em>{row.displayLabel}</em>
          </div>
          <div class="source-importance">
            <strong>{row.importance}</strong>
            <span>{row.priorityLabel} importance</span>
          </div>
          <div class="source-card-body">
            <p>{compactState(row.state)}</p>
          </div>
          <i aria-hidden="true"><b></b></i>
        </article>
      ))}
    </div>

    <div class="signal-theater">
      <div class="matrix-board" role="img" aria-label={`Signal decision matrix for ${entry.data.title}`}>
        <div class="matrix-radar" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="matrix-scan" aria-hidden="true"></div>
        <div class="matrix-axis matrix-axis-importance">Importance</div>
        <div class="matrix-axis matrix-axis-usefulness">Useful now → useful later</div>
        <div class="matrix-cross" aria-hidden="true"></div>
        <div class="matrix-quadrants">
          {quadrantFrames.map((quadrant, quadrantIndex) => (
            <section class={`matrix-cell matrix-cell-${quadrantIndex + 1}`}>
              <div class="matrix-cell-head">
                <span>{quadrant.title}</span>
                <strong>{quadrant.timing}</strong>
              </div>
            </section>
          ))}
        </div>
        <div class="matrix-point-layer">
          {quadrantSignals.map((signal) => (
            <article
              class={`matrix-signal-node matrix-quadrant-${signal.matrixIndex + 1} ${signal.bandClass}`}
              style={`--x:${signal.pointXPct}%; --y:${signal.pointYPct}%; --mobile-x:${signal.mobileXPct}%; --mobile-y:${signal.mobileYPct}%; --priority-delay:${signal.pulseDelay}s; --score:${signal.importance}%;`}
              aria-label={`Signal ${signal.signalNumber}: ${signal.displayLabel}, ${signal.importance} importance, ${signal.quadrantLabel}`}
            >
              <span class="node-pulse" aria-hidden="true"></span>
              <span class="node-number">{signal.signalNumber}</span>
              <span class="node-label">
                <strong>{signal.displayLabel}</strong>
                <em>{signal.importance} importance</em>
              </span>
            </article>
          ))}
        </div>
      </div>
    </div>

    <article class="action-column">
      <div class="action-meta">
        <span class="action-kicker">Decision Matrix</span>
        <div class="action-sequence" aria-hidden="true">
          <span>Score</span>
          <i></i>
          <span>Place</span>
          <i></i>
          <span>Use</span>
        </div>
      </div>
      <strong>{insight.signal}</strong>
      <p>{insight.micro}</p>
    </article>
  </div>

  <div class="signal-footer-line">
    <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
    <p>Same system every week, new signal each issue.</p>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    gap: clamp(16px, 3vw, 24px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background:
      radial-gradient(circle at 74% 20%, rgba(91, 140, 255, .18), transparent 23rem),
      radial-gradient(circle at 24% 76%, rgba(160, 108, 240, .1), transparent 20rem),
      linear-gradient(135deg, rgba(255, 255, 255, .96), rgba(240, 245, 255, .9));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .11);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-engine,
  .signal-footer-line {
    position: relative;
    z-index: 1;
  }

  .signal-map-copy {
    display: grid;
    grid-template-columns: minmax(190px, .42fr) minmax(320px, 1fr) auto;
    align-items: end;
    gap: clamp(14px, 2vw, 22px);
  }

  .signal-map-label,
  .signal-map-copy a,
  .source-card-head,
  .source-importance span,
  .action-kicker,
  .action-sequence,
  .signal-footer-line {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 3rem);
    line-height: .95;
  }

  .signal-map-intro {
    max-width: 60ch;
    margin: 0;
    color: #4f5d78;
    font-size: .95rem;
    line-height: 1.45;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .72);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
    white-space: nowrap;
  }

  .signal-engine {
    display: grid;
    grid-template-columns: minmax(210px, .62fr) minmax(560px, 1.7fr);
    gap: clamp(14px, 2.2vw, 24px);
    align-items: stretch;
  }

  .source-column {
    display: grid;
    gap: 10px;
    align-content: center;
  }

  .source-card {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    position: relative;
    display: grid;
    gap: .5rem;
    min-height: 128px;
    padding: .78rem .82rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .16);
    border-radius: 14px;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--signal-soft) 26%, transparent), transparent 42%),
      rgba(255, 255, 255, .84);
    box-shadow: 0 14px 28px rgba(46, 91, 208, .08);
    backdrop-filter: blur(10px);
    animation: sourceWake 5.8s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .source-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
  }

  .source-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 0 38%, rgba(255, 255, 255, .5) 48%, transparent 58% 100%);
    transform: translateX(-130%);
    animation: cardScan 6.6s ease-in-out infinite;
    animation-delay: calc(var(--delay) + .4s);
  }

  .source-indigo { --signal-accent: var(--indigo); --signal-soft: var(--indigo-soft); --signal-deep: var(--indigo-deep); }
  .source-azure { --signal-accent: var(--azure); --signal-soft: var(--azure-soft); --signal-deep: var(--azure-deep); }
  .source-violet { --signal-accent: var(--violet); --signal-soft: var(--violet-soft); --signal-deep: var(--violet-deep); }
  .source-gold { --signal-accent: var(--gold); --signal-soft: var(--gold-soft); --signal-deep: var(--gold-deep); }

  .source-card-head,
  .source-card-body,
  .source-card i {
    position: relative;
    z-index: 1;
  }

  .source-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    color: var(--signal-deep);
    font-size: .62rem;
    letter-spacing: .13em;
  }

  .source-card-head span {
    white-space: nowrap;
  }

  .source-card-head em {
    display: inline-flex;
    justify-content: flex-end;
    min-width: 0;
    color: var(--ink);
    font-style: normal;
    overflow-wrap: anywhere;
    text-align: right;
  }

  .source-importance {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: .7rem;
  }

  .source-importance strong {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.85rem);
    line-height: .82;
    letter-spacing: 0;
  }

  .source-importance span {
    display: inline-flex;
    align-items: center;
    min-height: 1.45rem;
    padding: 0 .52rem;
    border: 1px solid color-mix(in srgb, var(--signal-accent) 34%, transparent);
    border-radius: 999px;
    color: var(--signal-deep);
    font-size: .58rem;
    letter-spacing: .1em;
    background: rgba(255, 255, 255, .64);
    white-space: nowrap;
  }

  .source-card-body {
    display: grid;
    gap: .18rem;
  }

  .source-card-body p {
    margin: 0;
    color: #4d5a74;
    font-size: .78rem;
    line-height: 1.25;
  }

  .source-card i {
    height: 4px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .source-card b {
    display: block;
    width: var(--score);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px rgba(91, 140, 255, .36);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
  }

  .signal-theater {
    position: relative;
    min-height: 500px;
    overflow: hidden;
    padding: clamp(12px, 2vw, 18px);
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 18px;
    background:
      linear-gradient(90deg, rgba(46, 91, 208, .055) 1px, transparent 1px),
      linear-gradient(180deg, rgba(46, 91, 208, .045) 1px, transparent 1px),
      radial-gradient(circle at 34% 26%, rgba(91, 140, 255, .22), transparent 15rem),
      radial-gradient(circle at 70% 78%, rgba(201, 163, 94, .16), transparent 13rem),
      linear-gradient(145deg, rgba(247, 250, 255, .96), rgba(231, 238, 255, .88));
    background-size: 34px 34px, 34px 34px, auto, auto, auto;
    box-shadow: 0 24px 58px rgba(46, 91, 208, .14), inset 0 1px 0 rgba(255, 255, 255, .84);
    isolation: isolate;
  }

  .signal-theater::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(115deg, transparent 0 42%, rgba(255, 255, 255, .36) 50%, transparent 58% 100%);
    opacity: .46;
    pointer-events: none;
  }

  .matrix-board {
    position: relative;
    z-index: 1;
    min-height: 464px;
    height: 100%;
    padding: 2.55rem 1.55rem 2rem 3.15rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .13);
    border-radius: 16px;
    background:
      radial-gradient(circle at 50% 50%, rgba(91, 140, 255, .14), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, .54), rgba(241, 246, 255, .42));
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .62);
  }

  .matrix-radar {
    position: absolute;
    inset: 2.55rem 1.55rem 2rem 3.15rem;
    z-index: 1;
    overflow: hidden;
    border-radius: 12px;
    pointer-events: none;
  }

  .matrix-radar::before {
    content: "";
    position: absolute;
    inset: -18%;
    background:
      repeating-radial-gradient(circle at 50% 50%, transparent 0 54px, rgba(46, 91, 208, .13) 55px 56px, transparent 57px 108px),
      linear-gradient(90deg, transparent calc(50% - .5px), rgba(46, 91, 208, .14) 50%, transparent calc(50% + .5px)),
      linear-gradient(180deg, transparent calc(50% - .5px), rgba(46, 91, 208, .14) 50%, transparent calc(50% + .5px));
    opacity: .82;
  }

  .matrix-radar::after {
    content: "";
    position: absolute;
    inset: -22%;
    border-radius: 50%;
    background:
      conic-gradient(from -38deg at 50% 50%, transparent 0 70%, rgba(91, 140, 255, .34) 76%, rgba(201, 163, 94, .18) 82%, transparent 90% 100%);
    mix-blend-mode: multiply;
    opacity: .72;
    animation: radarSweep 9.5s linear infinite;
  }

  .matrix-radar span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 112px;
    height: 112px;
    border: 1px solid rgba(46, 91, 208, .24);
    border-radius: 50%;
    opacity: 0;
    transform: translate(-50%, -50%) scale(.2);
    animation: sonarPing 5.4s ease-out infinite;
  }

  .matrix-radar span:nth-child(2) {
    border-color: rgba(160, 108, 240, .22);
    animation-delay: 1.6s;
  }

  .matrix-radar span:nth-child(3) {
    border-color: rgba(201, 163, 94, .22);
    animation-delay: 3.2s;
  }

  .matrix-scan {
    position: absolute;
    inset: -18% auto -18% 46%;
    width: 32%;
    z-index: 1;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .58), transparent);
    transform: skewX(-13deg) translateX(-210%);
    animation: matrixScan 7.2s ease-in-out infinite;
    pointer-events: none;
  }

  .matrix-cross::before,
  .matrix-cross::after {
    content: "";
    position: absolute;
    z-index: 2;
    background: rgba(46, 91, 208, .2);
    pointer-events: none;
  }

  .matrix-cross::before {
    left: 50%;
    top: 2.55rem;
    bottom: 2rem;
    width: 1px;
  }

  .matrix-cross::after {
    left: 3.15rem;
    right: 1.55rem;
    top: 50%;
    height: 1px;
  }

  .matrix-axis,
  .matrix-cell-head span,
  .matrix-signal-node,
  .node-label em {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .matrix-axis {
    position: absolute;
    z-index: 3;
    color: rgba(46, 91, 208, .62);
    font-size: .58rem;
    letter-spacing: .14em;
    pointer-events: none;
  }

  .matrix-axis-importance {
    left: .7rem;
    top: 2.55rem;
    bottom: 2rem;
    width: 1.35rem;
    display: grid;
    place-items: center;
    padding: .55rem 0;
    border: 1px solid rgba(46, 91, 208, .16);
    border-radius: 999px;
    background: rgba(255, 255, 255, .54);
    box-shadow: 0 10px 22px rgba(46, 91, 208, .07);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .matrix-axis-usefulness {
    right: 1.55rem;
    bottom: .68rem;
  }

  .matrix-quadrants {
    position: relative;
