---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const concepts = insight.concepts.slice(0, 7);
const lanes = insight.lanes.slice(0, 4);

function signalBand(importance: number) {
  if (importance >= 90) return { className: 'signal-band-90', label: 'Prime signal' };
  if (importance >= 85) return { className: 'signal-band-85', label: 'Strong signal' };
  if (importance >= 80) return { className: 'signal-band-80', label: 'High signal' };
  if (importance >= 75) return { className: 'signal-band-75', label: 'Active signal' };
  if (importance >= 70) return { className: 'signal-band-70', label: 'Emerging signal' };
  if (importance >= 65) return { className: 'signal-band-65', label: 'Watch signal' };
  if (importance >= 60) return { className: 'signal-band-60', label: 'Low signal' };
  return { className: 'signal-band-55', label: 'Background signal' };
}

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 72 - index * 6));
  const band = signalBand(importance);
  const classificationLabel = lane.classification ?? lane.level;
  const strengthLabel = lane.strength ?? band.label;
  const fieldLabel = lane.field ?? lane.label;
  return {
    ...lane,
    fieldLabel,
    importance,
    classificationLabel,
    strengthLabel,
    sourceWeekLabel: lane.sourceWeek,
    meaningText: lane.meaning ?? lane.state,
    priorityLabel: band.label,
    bandClass: band.className,
  };
});
const orbit = [
  { label: insight.primaryTheme, level: 'Leading', state: `${insight.primaryTheme} is the primary theme.` },
  ...lanes.filter((lane) => (lane.field ?? lane.label).toLowerCase() !== insight.primaryTheme.toLowerCase()),
].slice(0, 4);
const nodePositions = [
  [19, 70],
  [32, 86],
  [48, 74],
  [62, 88],
  [80, 70],
  [68, 46],
  [31, 45],
];
const orbitPositions = [
  [50, 18],
  [82, 44],
  [50, 70],
  [18, 44],
];
const flowRoutes = concepts.map((concept, index) => {
  const [x, y] = nodePositions[index] ?? nodePositions[0];
  const controlA = [x + (50 - x) * .32, y - 14 - index * .8];
  const controlB = [50 + (x < 50 ? -7 : 7), 44 + (y < 44 ? -7 : 7)];
  return {
    concept,
    d: `M${x} ${y} C ${controlA[0]} ${controlA[1]}, ${controlB[0]} ${controlB[1]}, 50 44`,
    duration: 5.4 + index * .48,
    delay: index * .42,
  };
});
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <p class="signal-map-label">Latest Brief Signal</p>
    <h2 id="latest-signal-map">Signal Map</h2>
    <p>A compact reading of the newest brief: the central idea, active themes, and what deserves attention this week.</p>
    <a href={`/${entry.slug}/`}>Read the full brief</a>
  </div>

  <div class="signal-map-stage">
    <div class="signal-orbit-card" aria-label={`Signal map for ${entry.data.title}`}>
      <svg viewBox="0 0 100 100" role="img">
        <title>{`Signal map for ${entry.data.title}`}</title>
        <desc>{insight.signal}</desc>
        <defs>
          <radialGradient id="core-glow" cx="50%" cy="45%" r="55%">
            <stop offset="0%" stop-color="#ffffff" stop-opacity=".95" />
            <stop offset="40%" stop-color="#9DB8FF" stop-opacity=".86" />
            <stop offset="100%" stop-color="#2E5BD0" stop-opacity=".08" />
          </radialGradient>
          <linearGradient id="flow-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C9A35E" stop-opacity=".14" />
            <stop offset="48%" stop-color="#5B8CFF" stop-opacity=".48" />
            <stop offset="100%" stop-color="#2E5BD0" stop-opacity=".72" />
          </linearGradient>
          <filter id="signal-soft-glow" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur stdDeviation="1.2" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <rect class="map-frame" x="4" y="4" width="92" height="92" rx="6" />
        <path class="map-grid" d="M18 18H82M18 34H82M18 50H82M18 66H82M18 82H82M18 18V82M34 18V82M50 18V82M66 18V82M82 18V82" />
        <ellipse class="orbit-line orbit-a" cx="50" cy="44" rx="34" ry="23" />
        <ellipse class="orbit-line orbit-b" cx="50" cy="44" rx="24" ry="16" />

        <g class="flow-field" aria-hidden="true">
          {flowRoutes.map((route, index) => (
            <g class="flow-route-wrap" style={`--i:${index}`}>
              <path class="flow-route" d={route.d} />
              <path class="flow-route flow-route-echo" d={route.d} />
              <circle class={`flow-packet concept-${route.concept.type}`} r="1.15" filter="url(#signal-soft-glow)">
                <animateMotion dur={`${route.duration}s`} begin={`${route.delay}s`} repeatCount="indefinite" path={route.d} />
              </circle>
            </g>
          ))}
        </g>

        {concepts.map((concept, index) => {
          const [x, y] = nodePositions[index] ?? nodePositions[0];
          return (
            <g class={`concept concept-${concept.type}`} style={`--i:${index}`}>
              <line x1="50" y1="44" x2={x} y2={y} />
              <circle cx={x} cy={y} r="1.55" />
              <circle class="concept-ring" cx={x} cy={y} r="3.1" />
              <text x={x} y={y + 5}>{concept.label}</text>
            </g>
          );
        })}

        {orbit.map((theme, index) => {
          const [x, y] = orbitPositions[index] ?? orbitPositions[0];
          const orbitLabel = theme.field ?? theme.label;
          return (
            <g class={`orbit-node ${index === 0 ? 'is-primary' : ''}`} style={`--i:${index}`}>
              <circle cx={x} cy={y} r={index === 0 ? 4.2 : 3.2} />
              <text x={x} y={y - 6}>{orbitLabel}</text>
            </g>
          );
        })}

        <g class="core">
          <circle cx="50" cy="44" r="13" />
          <circle class="core-ring core-ring-a" cx="50" cy="44" r="17" />
          <circle class="core-ring core-ring-b" cx="50" cy="44" r="21" />
          <path d="M50 23 64 44 50 65 36 44Z" />
          <path d="M50 34 57 44 50 54 43 44Z" />
          <text class="decision-label" x="50" y="73">Next step</text>
        </g>
      </svg>
    </div>

    <div class="signal-lanes" aria-label="Current signals in this brief">
      <div class="signal-lanes-head">
        <span>Signals</span>
        <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
      </div>

      {signalRows.map((lane, index) => (
        <article class={`signal-strip ${lane.bandClass}`} style={`--i:${index}; --importance:${lane.importance}; --importance-pct:${lane.importance}%`}>
          <div class="signal-strip-main">
            <strong>{lane.fieldLabel}</strong>
            <span>{lane.classificationLabel}</span>
          </div>
          <div class="signal-strip-copy">
            <p>{lane.meaningText}</p>
            <div class="signal-strip-context">
              {lane.sourceWeekLabel && <span>{lane.sourceWeekLabel}</span>}
              <span>{lane.strengthLabel}</span>
            </div>
          </div>
          <div class="signal-priority" aria-label={`${lane.priorityLabel}: ${lane.importance} out of 100`}>
            <span>{lane.priorityLabel}</span>
            <i><b></b></i>
            <em>{lane.importance}</em>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, .34fr) minmax(0, 1fr);
    gap: clamp(18px, 3vw, 34px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background: radial-gradient(circle at 76% 18%, rgba(91, 140, 255, .18), transparent 22rem),
      linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(239, 244, 255, .8));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .12);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-map-stage {
    position: relative;
    z-index: 1;
  }

  .signal-map-label,
  .signal-map-copy a,
  .signal-lanes-head,
  .signal-strip-main span,
  .signal-priority,
  .signal-strip-context {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    max-width: 8ch;
    margin-bottom: .32em;
    font-size: clamp(2rem, 4.2vw, 3.8rem);
  }

  .signal-map-copy p:not(.signal-map-label) {
    max-width: 30ch;
    color: #4f5d78;
    font-size: .96rem;
    line-height: 1.48;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    margin-top: .4rem;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .68);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
  }

  .signal-map-stage {
    display: grid;
    gap: clamp(10px, 1.6vw, 14px);
  }

  .signal-orbit-card,
  .signal-lanes {
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 14px;
    background: rgba(255, 255, 255, .62);
    box-shadow: 0 16px 44px rgba(46, 91, 208, .09);
  }

  .signal-orbit-card {
    min-height: clamp(250px, 26vw, 340px);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .signal-orbit-card svg {
    width: min(100%, 560px);
    height: auto;
  }

  .map-frame {
    fill: rgba(248, 251, 255, .72);
    stroke: rgba(46, 91, 208, .2);
  }

  .map-grid {
    fill: none;
    stroke: rgba(46, 91, 208, .07);
    stroke-width: .25;
  }

  .orbit-line {
    fill: none;
    stroke: rgba(46, 91, 208, .32);
    stroke-dasharray: 1.6 2.8;
    animation: trace 12s linear infinite;
  }

  .orbit-b {
    animation-direction: reverse;
    animation-duration: 9s;
  }

  .flow-field {
    mix-blend-mode: multiply;
  }

  .flow-route-wrap {
    opacity: 0;
    animation: rise .8s ease both;
    animation-delay: calc(var(--i) * 80ms + 120ms);
  }

  .flow-route {
    fill: none;
    stroke: url(#flow-gradient);
    stroke-width: .42;
    stroke-linecap: round;
    stroke-dasharray: 1 4.5;
    opacity: .48;
    animation: flowTrace 8s linear infinite;
    animation-delay: calc(var(--i) * -420ms);
  }

  .flow-route-echo {
    stroke-width: 1.4;
    stroke: rgba(91, 140, 255, .08);
    stroke-dasharray: none;
    opacity: .6;
    animation: none;
  }

  .flow-packet {
    fill: #2E5BD0;
    stroke: #fff;
    stroke-width: .36;
    opacity: .92;
  }

  .flow-packet.concept-service { fill: var(--gold); }
  .flow-packet.concept-leadership { fill: var(--violet); }
  .flow-packet.concept-learning { fill: var(--indigo); }
  .flow-packet.concept-technology { fill: var(--azure-deep); }
  .flow-packet.concept-work { fill: #A06CF0; }

  .concept {
    opacity: 0;
    animation: rise .7s ease both;
    animation-delay: calc(var(--i) * 90ms + 180ms);
  }

  .concept line {
    stroke: rgba(46, 91, 208, .12);
    stroke-dasharray: 1 2;
  }

  .concept circle:not(.concept-ring) {
    fill: var(--azure);
    stroke: #fff;
    stroke-width: .8;
  }

  .concept-ring {
    fill: none;
    stroke: rgba(46, 91, 208, .18);
    stroke-width: .42;
    transform-origin: center;
    animation: nodePing 3.8s ease-in-out infinite;
    animation-delay: calc(var(--i) * 260ms);
  }

  .concept-service circle:not(.concept-ring) { fill: var(--gold); }
  .concept-leadership circle:not(.concept-ring) { fill: var(--violet); }
  .concept-learning circle:not(.concept-ring) { fill: var(--indigo); }
  .concept-technology circle:not(.concept-ring) { fill: var(--azure-deep); }
  .concept-work circle:not(.concept-ring) { fill: #A06CF0; }

  .concept text,
  .orbit-node text,
  .decision-label {
    fill: #24314d;
    font-family: var(--font-label);
    font-size: 2.6px;
    font-weight: 800;
    text-anchor: middle;
  }

  .decision-label {
    fill: var(--azure-deep);
    font-size: 2.85px;
    letter-spacing: .04em;
  }

  .orbit-node {
    opacity: 0;
    animation: rise .7s ease both;
    animation-delay: calc(var(--i) * 120ms + 80ms);
  }

  .orbit-node circle {
    fill: rgba(157, 184, 255, .7);
    stroke: rgba(46, 91, 208, .36);
    stroke-width: .45;
  }

  .orbit-node.is-primary circle {
    fill: rgba(91, 140, 255, .95);
    stroke: #fff;
    stroke-width: .9;
    animation: pulse 2.8s ease-in-out infinite;
  }

  .core circle:first-child {
    fill: url(#core-glow);
    animation: breathe 3.6s ease-in-out infinite;
  }

  .core-ring {
    fill: none;
    stroke: rgba(46, 91, 208, .18);
    stroke-width: .45;
    transform-origin: center;
  }

  .core-ring-a {
    animation: coreWave 3.4s ease-in-out infinite;
  }

  .core-ring-b {
    stroke: rgba(201, 163, 94, .24);
    animation: coreWave 3.4s ease-in-out infinite;
    animation-delay: 1.1s;
  }

  .core path:first-of-type {
    fill: rgba(255, 255, 255, .9);
    stroke: rgba(46, 91, 208, .72);
    stroke-width: .55;
  }

  .core path:last-of-type {
    fill: var(--azure-deep);
    opacity: .9;
  }

  .signal-lanes {
    display: grid;
    gap: 6px;
    padding: clamp(10px, 1.3vw, 13px);
    overflow: hidden;
  }

  .signal-lanes-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 0 2px 2px;
    color: var(--azure-deep);
    font-size: .66rem;
    letter-spacing: .14em;
  }

  .signal-lanes-head span:last-child {
    color: #6a7893;
    text-align: right;
  }

  .signal-strip {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    --signal-wash: rgba(91, 140, 255, .13);
    --signal-glow: rgba(91, 140, 255, .46);
    position: relative;
    display: grid;
    grid-template-columns: minmax(112px, .34fr) minmax(0, 1fr) minmax(128px, .3fr);
    align-items: center;
    gap: clamp(10px, 2vw, 18px);
    min-height: 58px;
    padding: .58rem .72rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .13);
    border-radius: 10px;
    background:
      linear-gradient(90deg, var(--signal-wash), transparent var(--importance-pct)),
      rgba(255, 255, 255, .7);
    box-shadow: 0 10px 24px rgba(46, 91, 208, .07);
    opacity: 0;
    animation: laneReveal .72s ease both;
    animation-delay: calc(var(--i) * 90ms + 280ms);
  }

  .signal-strip::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-accent), var(--signal-deep));
    opacity: .9;
  }

  .signal-strip-main,
  .signal-strip-copy {
    display: grid;
    gap: 2px;
  }

  .signal-strip-main strong {
    color: var(--ink);
    font-family: var(--font-label);
    font-size: .86rem;
    letter-spacing: .01em;
  }

  .signal-strip-main span {
    color: var(--signal-deep);
    font-size: .62rem;
    letter-spacing: .13em;
  }

  .signal-strip p {
    margin: 0;
    color: #4d5a74;
    font-size: .84rem;
    line-height: 1.26;
  }

  .signal-strip-context {
    display: flex;
    flex-wrap: wrap;
    gap: 5px 8px;
    color: var(--signal-deep);
    font-size: .56rem;
    letter-spacing: .1em;
  }

  .signal-strip-context span + span::before {
    content: "•";
    margin-right: 8px;
    color: #8a97b8;
  }

  .signal-priority {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 5px 8px;
    color: var(--signal-deep);
    font-size: .6rem;
    letter-spacing: .1em;
  }

  .signal-priority i {
    grid-column: 1 / -1;
    position: relative;
    height: 5px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .signal-priority b {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--importance-pct);
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px var(--signal-glow);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
    animation-delay: calc(var(--i) * 90ms + 440ms);
  }

  .signal-priority em {
    color: var(--ink);
    font-style: normal;
  }

  .signal-band-90 {
    --signal-accent: #2E5BD0;
    --signal-soft: #9DB8FF;
    --signal-deep: #163C9C;
    --signal-wash: rgba(46, 91, 208, .18);
    --signal-glow: rgba(46, 91, 208, .5);
  }

  .signal-band-85 {
    --signal-accent: #5B8CFF;
    --signal-soft: #B9CAFF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(91, 140, 255, .16);
    --signal-glow: rgba(91, 140, 255, .48);
  }

  .signal-band-80 {
    --signal-accent: #6E74F0;
    --signal-soft: #A9AEFF;
    --signal-deep: #3840BD;
    --signal-wash: rgba(110, 116, 240, .15);
    --signal-glow: rgba(110, 116, 240, .44);
  }

  .signal-band-75 {
    --signal-accent: #A06CF0;
    --signal-soft: #C9A8FF;
    --signal-deep: #6C36C2;
    --signal-wash: rgba(160, 108, 240, .14);
    --signal-glow: rgba(160, 108, 240, .42);
  }

  .signal-band-70 {
    --signal-accent: #C9A35E;
    --signal-soft: #E6CB8E;
    --signal-deep: #8C6526;
    --signal-wash: rgba(201, 163, 94, .15);
    --signal-glow: rgba(201, 163, 94, .42);
  }

  .signal-band-65 {
    --signal-accent: #7FA3FF;
    --signal-soft: #C8D6FF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(127, 163, 255, .13);
    --signal-glow: rgba(127, 163, 255, .38);
  }

  .signal-band-60 {
    --signal-accent: #7F86E8;
    --signal-soft: #C8CBFF;
    --signal-deep: #4D55B5;
    --signal-wash: rgba(127, 134, 232, .12);
    --signal-glow: rgba(127, 134, 232, .34);
  }

  .signal-band-55 {
    --signal-accent: #8A97B8;
    --signal-soft: #D7DEEF;
    --signal-deep: #52617C;
    --signal-wash: rgba(138, 151, 184, .11);
    --signal-glow: rgba(138, 151, 184, .28);
  }

  @keyframes trace { to { stroke-dashoffset: -40; } }
  @keyframes flowTrace { to { stroke-dashoffset: -42; } }
  @keyframes rise { from { opacity: 0; transform: translateY(2px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes laneReveal { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes priorityFill { from { transform: scaleX(.18); } to { transform: scaleX(1); } }
  @keyframes pulse { 50% { filter: drop-shadow(0 0 3px rgba(91, 140, 255, .7)); } }
  @keyframes breathe { 50% { opacity: .72; } }
  @keyframes nodePing { 50% { transform: scale(1.18); opacity: .42; } }
  @keyframes coreWave { 0% { transform: scale(.82); opacity: 0; } 35% { opacity: .62; } 100% { transform: scale(1.12); opacity: 0; } }

  @media (max-width: 1020px) {
    .signal-insight-map,
    .signal-map-stage {
      grid-template-columns: 1fr;
    }

    .signal-map-copy h2 {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .signal-insight-map {
      padding: 18px 14px;
    }

    .signal-orbit-card {
      min-height: 230px;
    }

    .signal-orbit-card svg {
      width: 122%;
    }

    .signal-lanes-head,
    .signal-strip {
      grid-template-columns: 1fr;
    }

    .signal-lanes-head {
      display: grid;
    }

    .signal-lanes-head span:last-child {
      text-align: left;
    }

    .signal-strip {
      gap: 8px;
      min-height: 0;
    }

    .signal-priority {
      grid-template-columns: auto 1fr auto;
    }

    .signal-priority i {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit-line,
    .flow-route,
    .concept,
    .concept-ring,
    .orbit-node,
    .orbit-node.is-primary circle,
    .core circle,
    .core-ring,
    .signal-strip,
    .signal-priority b {
      animation: none;
      opacity: 1;
    }

    .flow-packet {
      display: none;
    }
  }
</style>
