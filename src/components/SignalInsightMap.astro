---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const lanes = insight.lanes.slice(0, 4);

type QuadrantKey = 'high-now' | 'high-later' | 'low-now' | 'low-later';

const controlledLabelMap: Record<string, string> = {
  school: 'Education',
  learning: 'Education',
  education: 'Education',
  technology: 'Tech',
  tech: 'Tech',
  people: 'Community',
  community: 'Community',
  money: 'Market',
  market: 'Market',
  trust: 'Society',
  society: 'Society',
};

function displayField(value?: string) {
  const cleaned = String(value ?? '').trim();
  return controlledLabelMap[cleaned.toLowerCase()] ?? cleaned;
}

function signalBand(importance: number) {
  if (importance >= 90) return { className: 'signal-band-90', label: 'Prime' };
  if (importance >= 85) return { className: 'signal-band-85', label: 'Strong' };
  if (importance >= 80) return { className: 'signal-band-80', label: 'High' };
  if (importance >= 75) return { className: 'signal-band-75', label: 'Active' };
  if (importance >= 70) return { className: 'signal-band-70', label: 'Emerging' };
  if (importance >= 65) return { className: 'signal-band-65', label: 'Watch' };
  if (importance >= 60) return { className: 'signal-band-60', label: 'Quiet' };
  return { className: 'signal-band-55', label: 'Background' };
}

function compactState(value?: string) {
  if (!value) return 'A visible pressure point in this week\'s brief.';
  return value.length > 88 ? `${value.slice(0, 85).trim()}...` : value;
}

const quadrantFrames = [
  {
    key: 'high-now' as QuadrantKey,
    title: 'High importance',
    timing: 'Useful now',
    shortLabel: 'High + now',
    x: 48,
    y: 54,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 128,
  },
  {
    key: 'high-later' as QuadrantKey,
    title: 'High importance',
    timing: 'Useful later',
    shortLabel: 'High + later',
    x: 312,
    y: 54,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 128,
  },
  {
    key: 'low-now' as QuadrantKey,
    title: 'Lower importance',
    timing: 'Useful now',
    shortLabel: 'Lower + now',
    x: 48,
    y: 228,
    width: 240,
    height: 138,
    pointX: 164,
    pointY: 300,
  },
  {
    key: 'low-later' as QuadrantKey,
    title: 'Lower importance',
    timing: 'Useful later',
    shortLabel: 'Lower + later',
    x: 312,
    y: 228,
    width: 240,
    height: 138,
    pointX: 430,
    pointY: 300,
  },
];

const quadrantByKey = Object.fromEntries(quadrantFrames.map((frame) => [frame.key, frame])) as Record<QuadrantKey, typeof quadrantFrames[number]>;

function laneSearchText(lane: typeof lanes[number]) {
  return [
    lane.label,
    lane.field,
    lane.level,
    lane.state,
    lane.strength,
    lane.classification,
    lane.meaning,
    lane.brief,
  ].filter(Boolean).join(' ').toLowerCase();
}

function usefulnessFor(lane: typeof lanes[number]) {
  if (typeof lane.usefulness === 'number') return Math.min(100, Math.max(0, lane.usefulness));
  if (lane.timeframe === 'now') return 78;
  if (lane.timeframe === 'later') return 34;

  const text = laneSearchText(lane);
  let score = 48;

  if (lane.direction === 'up') score += 16;
  if (lane.direction === 'down') score -= 10;
  if (lane.direction === 'steady') score -= 4;
  if (/\b(urgent|immediate|now|today|current|active|rising|action|operate|operating|decision|support|practice)\b/.test(text)) score += 18;
  if (/\b(later|future|watch|watching|emerging|monitor|next|developing|longer-term)\b/.test(text)) score -= 28;
  if (/\b(confirmed|strong|prime|leading)\b/.test(text)) score += 8;

  return Math.min(100, Math.max(0, score));
}

function quadrantKeyFor(lane: typeof lanes[number], importance: number, usefulness: number): QuadrantKey {
  if (lane.quadrant) return lane.quadrant;
  const highImportance = importance >= 82;
  const usefulNow = usefulness >= 60;

  if (highImportance && usefulNow) return 'high-now';
  if (highImportance) return 'high-later';
  if (usefulNow) return 'low-now';
  return 'low-later';
}

const quadrantSlots = [
  { dx: 0, dy: 0 },
  { dx: -42, dy: 24 },
  { dx: 42, dy: 24 },
  { dx: 0, dy: -26 },
];

const sourceTones = ['source-indigo', 'source-azure', 'source-violet', 'source-gold'];
const quadrantUseCounts: Record<number, number> = {};

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 76 - index * 6));
  const usefulness = usefulnessFor(lane);
  const quadrantKey = quadrantKeyFor(lane, importance, usefulness);
  const band = signalBand(importance);
  const displayLabel = displayField(lane.field ?? lane.label);
  const frame = quadrantByKey[quadrantKey];
  const matrixIndex = quadrantFrames.findIndex((quadrant) => quadrant.key === quadrantKey);
  const slot = quadrantSlots[quadrantUseCounts[matrixIndex] ?? 0] ?? quadrantSlots[0];
  quadrantUseCounts[matrixIndex] = (quadrantUseCounts[matrixIndex] ?? 0) + 1;

  return {
    ...lane,
    displayLabel,
    importance,
    usefulness,
    quadrantKey,
    matrixIndex,
    priorityLabel: band.label,
    bandClass: band.className,
    tone: sourceTones[index % sourceTones.length],
    delay: (index * -1.1).toFixed(1),
    ...frame,
    pointX: frame.pointX + slot.dx,
    pointY: frame.pointY + slot.dy,
    quadrantLabel: frame.shortLabel,
    timingLabel: usefulness >= 60 ? 'Useful now' : 'Useful later',
  };
});

const sourceRows = signalRows;
const quadrantSignals = signalRows.slice(0, 4);
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <div>
      <p class="signal-map-label">Latest Signals Brief</p>
      <h2 id="latest-signal-map">Signal Map</h2>
    </div>
    <p class="signal-map-intro">A live decision field for the week: each signal is placed by importance and usefulness so the next move is easier to read.</p>
    <a href={`/${entry.slug}/`}>Read the full story</a>
  </div>

  <div class="signal-engine" aria-label={`Signal map for ${entry.data.title}`}>
    <div class="source-column" aria-label="Weekly signal priority lanes">
      {sourceRows.map((row) => (
        <article
          class={`source-card ${row.tone} ${row.bandClass}`}
          style={`--score:${row.importance}%; --delay:${row.delay}s;`}
        >
          <div class="source-card-head">
            <span>{row.displayLabel}</span>
            <em>{row.importance}</em>
          </div>
          <div class="source-card-body">
            <strong>{row.quadrantLabel}</strong>
            <p>{compactState(row.state)}</p>
          </div>
          <i aria-hidden="true"><b></b></i>
        </article>
      ))}
    </div>

    <div class="signal-theater">
      <div class="matrix-board" role="img" aria-label={`Signal decision matrix for ${entry.data.title}`}>
        <div class="matrix-scan" aria-hidden="true"></div>
        <div class="matrix-axis matrix-axis-importance">Importance</div>
        <div class="matrix-axis matrix-axis-usefulness">Useful now → useful later</div>
        <div class="matrix-cross" aria-hidden="true"></div>
        <div class="matrix-quadrants">
          {quadrantFrames.map((quadrant, quadrantIndex) => (
            <section class={`matrix-cell matrix-cell-${quadrantIndex + 1}`}>
              <div class="matrix-cell-head">
                <span>{quadrant.title}</span>
                <strong>{quadrant.timing}</strong>
              </div>
              <div class="matrix-signal-stack">
                {quadrantSignals.filter((signal) => signal.quadrantKey === quadrant.key).map((signal, signalIndex) => (
                  <article
                    class={`matrix-signal-card ${signal.bandClass}`}
                    style={`--priority-delay:${(quadrantIndex + signalIndex) * 0.12}s; --score:${signal.importance}%;`}
                  >
                    <div>
                      <span>{signal.displayLabel}</span>
                      <em>{signal.level} · {signal.importance}</em>
                    </div>
                    <p>{signal.meaning ?? compactState(signal.state)}</p>
                    <i aria-hidden="true"><b></b></i>
                  </article>
                ))}
                {quadrantSignals.filter((signal) => signal.quadrantKey === quadrant.key).length === 0 && (
                  <p class="matrix-empty">No primary signal placed here this week.</p>
                )}
              </div>
            </section>
          ))}
        </div>
      </div>
    </div>

    <article class="action-column">
      <span class="action-kicker">Decision Matrix</span>
      <strong>{insight.signal}</strong>
      <p>{insight.micro}</p>
      <div class="action-sequence" aria-hidden="true">
        <span>Score</span>
        <i></i>
        <span>Place</span>
        <i></i>
        <span>Use</span>
      </div>
    </article>
  </div>

  <div class="signal-footer-line">
    <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
    <p>Same system every week, new signal each issue.</p>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    gap: clamp(16px, 3vw, 24px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background:
      radial-gradient(circle at 74% 20%, rgba(91, 140, 255, .18), transparent 23rem),
      radial-gradient(circle at 24% 76%, rgba(160, 108, 240, .1), transparent 20rem),
      linear-gradient(135deg, rgba(255, 255, 255, .96), rgba(240, 245, 255, .9));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .11);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-engine,
  .signal-footer-line {
    position: relative;
    z-index: 1;
  }

  .signal-map-copy {
    display: grid;
    grid-template-columns: minmax(190px, .42fr) minmax(320px, 1fr) auto;
    align-items: end;
    gap: clamp(14px, 2vw, 22px);
  }

  .signal-map-label,
  .signal-map-copy a,
  .source-card-head,
  .source-card-body strong,
  .action-kicker,
  .action-sequence,
  .signal-footer-line {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    margin: 0;
    font-size: clamp(1.9rem, 3.4vw, 3rem);
    line-height: .95;
  }

  .signal-map-intro {
    max-width: 60ch;
    margin: 0;
    color: #4f5d78;
    font-size: .95rem;
    line-height: 1.45;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .72);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
    white-space: nowrap;
  }

  .signal-engine {
    display: grid;
    grid-template-columns: minmax(210px, .62fr) minmax(560px, 1.7fr);
    gap: clamp(14px, 2.2vw, 24px);
    align-items: stretch;
  }

  .source-column {
    display: grid;
    gap: 10px;
    align-content: center;
  }

  .source-card {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    position: relative;
    display: grid;
    gap: .44rem;
    min-height: 96px;
    padding: .74rem .78rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .16);
    border-radius: 14px;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--signal-soft) 26%, transparent), transparent 42%),
      rgba(255, 255, 255, .84);
    box-shadow: 0 14px 28px rgba(46, 91, 208, .08);
    backdrop-filter: blur(10px);
    animation: sourceWake 5.8s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  .source-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
  }

  .source-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, transparent 0 38%, rgba(255, 255, 255, .5) 48%, transparent 58% 100%);
    transform: translateX(-130%);
    animation: cardScan 6.6s ease-in-out infinite;
    animation-delay: calc(var(--delay) + .4s);
  }

  .source-indigo { --signal-accent: var(--indigo); --signal-soft: var(--indigo-soft); --signal-deep: var(--indigo-deep); }
  .source-azure { --signal-accent: var(--azure); --signal-soft: var(--azure-soft); --signal-deep: var(--azure-deep); }
  .source-violet { --signal-accent: var(--violet); --signal-soft: var(--violet-soft); --signal-deep: var(--violet-deep); }
  .source-gold { --signal-accent: var(--gold); --signal-soft: var(--gold-soft); --signal-deep: var(--gold-deep); }

  .source-card-head,
  .source-card-body,
  .source-card i {
    position: relative;
    z-index: 1;
  }

  .source-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
    color: var(--signal-deep);
    font-size: .62rem;
    letter-spacing: .13em;
  }

  .source-card-head em {
    display: inline-grid;
    place-items: center;
    min-width: 2.1rem;
    min-height: 1.3rem;
    border: 1px solid color-mix(in srgb, var(--signal-accent) 34%, transparent);
    border-radius: 999px;
    color: var(--ink);
    font-style: normal;
    background: rgba(255, 255, 255, .58);
  }

  .source-card-body {
    display: grid;
    gap: .18rem;
  }

  .source-card-body strong {
    color: var(--ink);
    font-size: .73rem;
    letter-spacing: .08em;
  }

  .source-card-body p {
    margin: 0;
    color: #4d5a74;
    font-size: .78rem;
    line-height: 1.25;
  }

  .source-card i {
    height: 4px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .source-card b {
    display: block;
    width: var(--score);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px rgba(91, 140, 255, .36);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
  }

  .signal-theater {
    position: relative;
    min-height: 500px;
    overflow: hidden;
    padding: clamp(12px, 2vw, 18px);
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 18px;
    background:
      linear-gradient(90deg, rgba(46, 91, 208, .055) 1px, transparent 1px),
      linear-gradient(180deg, rgba(46, 91, 208, .045) 1px, transparent 1px),
      radial-gradient(circle at 34% 26%, rgba(91, 140, 255, .22), transparent 15rem),
      radial-gradient(circle at 70% 78%, rgba(201, 163, 94, .16), transparent 13rem),
      linear-gradient(145deg, rgba(247, 250, 255, .96), rgba(231, 238, 255, .88));
    background-size: 34px 34px, 34px 34px, auto, auto, auto;
    box-shadow: 0 24px 58px rgba(46, 91, 208, .14), inset 0 1px 0 rgba(255, 255, 255, .84);
    isolation: isolate;
  }

  .signal-theater::before {
    content: "";
    position: absolute;
    inset: 13%;
    border-radius: 50%;
    background:
      conic-gradient(from 0deg, transparent, rgba(91, 140, 255, .26), transparent, rgba(160, 108, 240, .2), transparent, rgba(201, 163, 94, .2), transparent);
    filter: blur(14px);
    opacity: .82;
    animation: chamberTurn 24s linear infinite;
  }

  .matrix-board {
    position: relative;
    z-index: 1;
    min-height: 464px;
    height: 100%;
    padding: 2.55rem 1.55rem 2rem 2.15rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .13);
    border-radius: 16px;
    background: rgba(255, 255, 255, .42);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .62);
  }

  .matrix-scan {
    position: absolute;
    inset: -18% auto -18% 46%;
    width: 32%;
    z-index: 1;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .58), transparent);
    transform: skewX(-13deg) translateX(-210%);
    animation: matrixScan 7.2s ease-in-out infinite;
    pointer-events: none;
  }

  .matrix-cross::before,
  .matrix-cross::after {
    content: "";
    position: absolute;
    z-index: 2;
    background: rgba(46, 91, 208, .2);
    pointer-events: none;
  }

  .matrix-cross::before {
    left: 50%;
    top: 2.55rem;
    bottom: 2rem;
    width: 1px;
  }

  .matrix-cross::after {
    left: 2.15rem;
    right: 1.55rem;
    top: 50%;
    height: 1px;
  }

  .matrix-axis,
  .matrix-cell-head span,
  .matrix-signal-card span,
  .matrix-signal-card em {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .matrix-axis {
    position: absolute;
    z-index: 3;
    color: rgba(46, 91, 208, .62);
    font-size: .58rem;
    letter-spacing: .14em;
    pointer-events: none;
  }

  .matrix-axis-importance {
    left: .65rem;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
  }

  .matrix-axis-usefulness {
    right: 1.55rem;
    bottom: .68rem;
  }

  .matrix-quadrants {
    position: relative;
    z-index: 4;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: 12px;
    height: 100%;
  }

  .matrix-cell {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: .68rem;
    min-height: 0;
    padding: .9rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .15);
    border-radius: 15px;
    background: rgba(255, 255, 255, .58);
    box-shadow: 0 14px 24px rgba(46, 91, 208, .07);
    animation: cellBreath 7.2s ease-in-out infinite;
  }

  .matrix-cell::after {
    content: "";
    position: absolute;
    inset: auto 10px 10px auto;
    width: 58px;
    height: 58px;
    border-top: 1px solid rgba(46, 91, 208, .18);
    border-right: 1px solid rgba(46, 91, 208, .18);
    pointer-events: none;
  }

  .matrix-cell-1 {
    background: linear-gradient(135deg, rgba(91, 140, 255, .18), rgba(255, 255, 255, .64));
  }

  .matrix-cell-2 {
    background: linear-gradient(135deg, rgba(160, 108, 240, .14), rgba(255, 255, 255, .62));
  }

  .matrix-cell-3 {
    background: linear-gradient(135deg, rgba(201, 163, 94, .15), rgba(255, 255, 255, .62));
  }

  .matrix-cell-4 {
    background: linear-gradient(135deg, rgba(79, 182, 168, .13), rgba(255, 255, 255, .62));
  }

  .matrix-cell-2 { animation-delay: -1.4s; }
  .matrix-cell-3 { animation-delay: -2.2s; }
  .matrix-cell-4 { animation-delay: -3s; }

  .matrix-cell-head {
    position: relative;
    z-index: 1;
    display: grid;
    gap: .18rem;
  }

  .matrix-cell-head span {
    color: rgba(36, 49, 77, .7);
    font-size: .58rem;
    letter-spacing: .12em;
  }

  .matrix-cell-head strong {
    color: var(--azure-deep);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.7vw, 1.22rem);
    line-height: .98;
  }

  .matrix-signal-stack {
    position: relative;
    z-index: 1;
    display: grid;
    gap: .46rem;
    align-content: start;
    min-height: 0;
  }

  .matrix-signal-card {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    position: relative;
    display: grid;
    gap: .32rem;
    padding: .55rem .6rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--signal-accent) 25%, transparent);
    border-left: 4px solid var(--signal-accent);
    border-radius: 11px;
    background: rgba(255, 255, 255, .76);
    box-shadow: 0 12px 20px color-mix(in srgb, var(--signal-accent) 13%, transparent);
    animation: prioritySignalRise 780ms ease both, signalDrift 5.8s ease-in-out infinite;
    animation-delay: var(--priority-delay);
  }

  .matrix-signal-card div {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .5rem;
  }

  .matrix-signal-card span {
    color: var(--signal-deep);
    font-size: .64rem;
    letter-spacing: .12em;
  }

  .matrix-signal-card em {
    color: rgba(36, 49, 77, .62);
    font-size: .54rem;
    font-style: normal;
    letter-spacing: .08em;
    white-space: nowrap;
  }

  .matrix-signal-card p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: #43516d;
    font-size: .67rem;
    line-height: 1.28;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .matrix-signal-card i {
    height: 3px;
    overflow: hidden;
    border-radius: 999px;
    background: color-mix(in srgb, var(--signal-soft) 30%, transparent);
  }

  .matrix-signal-card b {
    display: block;
    width: var(--score);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
  }

  .matrix-empty {
    align-self: center;
    margin: 0;
    padding: .72rem;
    border: 1px dashed rgba(46, 91, 208, .2);
    border-radius: 12px;
    color: rgba(67, 81, 109, .7);
    font-size: .72rem;
    line-height: 1.3;
