---
import type { CollectionEntry } from 'astro:content';
import { formatDate, formatIssue } from '../utils/format';
import type { SignalInsight } from '../utils/signalInsight';

interface Props {
  entry: CollectionEntry<'signals'>;
  insight: SignalInsight;
}

const { entry, insight } = Astro.props as Props;
const concepts = insight.concepts.slice(0, 7);
const visibleConcepts = concepts.slice(0, 5);
const lanes = insight.lanes.slice(0, 4);

function signalBand(importance: number) {
  if (importance >= 90) return { className: 'signal-band-90', label: 'Prime signal' };
  if (importance >= 85) return { className: 'signal-band-85', label: 'Strong signal' };
  if (importance >= 80) return { className: 'signal-band-80', label: 'High signal' };
  if (importance >= 75) return { className: 'signal-band-75', label: 'Active signal' };
  if (importance >= 70) return { className: 'signal-band-70', label: 'Emerging signal' };
  if (importance >= 65) return { className: 'signal-band-65', label: 'Watch signal' };
  if (importance >= 60) return { className: 'signal-band-60', label: 'Low signal' };
  return { className: 'signal-band-55', label: 'Background signal' };
}

const signalRows = lanes.map((lane, index) => {
  const importance = Math.min(100, Math.max(0, lane.importance ?? 72 - index * 6));
  const band = signalBand(importance);
  return {
    ...lane,
    importance,
    priorityLabel: band.label,
    bandClass: band.className,
  };
});
const orbit = [
  { label: insight.primaryTheme, level: 'Leading', state: `${insight.primaryTheme} is the primary theme.` },
  ...lanes.filter((lane) => lane.label.toLowerCase() !== insight.primaryTheme.toLowerCase()),
].slice(0, 4);
const methodSummary = signalRows
  .map((lane) => `${lane.label} ${lane.importance}`)
  .join(' · ');
const nodePositions = [
  [19, 70],
  [32, 86],
  [48, 74],
  [62, 88],
  [80, 70],
  [68, 46],
  [31, 45],
];
const orbitPositions = [
  [50, 18],
  [82, 44],
  [50, 70],
  [18, 44],
];
---

<section class="signal-insight-map reveal" aria-labelledby="latest-signal-map">
  <div class="signal-map-copy">
    <p class="signal-map-label">Latest Brief Signal</p>
    <h2 id="latest-signal-map">Signal Map</h2>
    <p>A compact reading of the newest brief: the central idea, active themes, and what deserves attention this week.</p>
    <a href={`/${entry.slug}/`}>Read the full story</a>
    <div class="signal-map-notes" aria-label="Signal method notes">
      <article>
        <strong>Method</strong>
        <p>Signal strength follows the lead pattern, lane importance, and how clearly the note points to the next useful move.</p>
      </article>
      <article>
        <strong>Update</strong>
        <p>The map reads from the newest note's signal, micro, concepts, and lane scores: {methodSummary}.</p>
      </article>
    </div>
  </div>

  <div class="signal-map-stage">
    <div class="signal-orbit-card" aria-label={`Signal map for ${entry.data.title}`}>
      <div class="signal-orbit-figure">
        <svg viewBox="0 0 100 100" role="img">
          <title>{`Signal map for ${entry.data.title}`}</title>
          <desc>{insight.signal}</desc>
          <defs>
            <radialGradient id="core-glow" cx="50%" cy="45%" r="55%">
              <stop offset="0%" stop-color="#9DB8FF" stop-opacity=".9" />
              <stop offset="55%" stop-color="#5B8CFF" stop-opacity=".28" />
              <stop offset="100%" stop-color="#2E5BD0" stop-opacity=".04" />
            </radialGradient>
          </defs>
          <rect class="map-frame" x="4" y="4" width="92" height="92" rx="6" />
          <path class="map-grid" d="M18 18H82M18 34H82M18 50H82M18 66H82M18 82H82M18 18V82M34 18V82M50 18V82M66 18V82M82 18V82" />
          <ellipse class="orbit-line orbit-a" cx="50" cy="44" rx="34" ry="23" />
          <ellipse class="orbit-line orbit-b" cx="50" cy="44" rx="24" ry="16" />

          {concepts.map((concept, index) => {
            const [x, y] = nodePositions[index] ?? nodePositions[0];
            return (
              <g class={`concept concept-${concept.type}`} style={`--i:${index}`}>
                <line x1="50" y1="44" x2={x} y2={y} />
                <circle cx={x} cy={y} r="1.55" />
              </g>
            );
          })}

          {orbit.map((theme, index) => {
            const [x, y] = orbitPositions[index] ?? orbitPositions[0];
            return (
              <g class={`orbit-node ${index === 0 ? 'is-primary' : ''}`} style={`--i:${index}`}>
                <circle cx={x} cy={y} r={index === 0 ? 4.2 : 3.2} />
                <text x={x} y={y - 6}>{theme.label}</text>
              </g>
            );
          })}

          <g class="core">
            <circle cx="50" cy="44" r="13" />
            <path d="M50 23 64 44 50 65 36 44Z" />
            <path d="M50 34 57 44 50 54 43 44Z" />
          </g>
        </svg>
      </div>

      <div class="signal-orbit-copy">
        <p class="signal-orbit-label">Primary signal</p>
        <h3>{insight.signal}</h3>
        <p>{insight.micro}</p>
        <div class="signal-concept-list" aria-label="Concept threads in this brief">
          {visibleConcepts.map((concept) => (
            <span class={`signal-concept-chip signal-concept-${concept.type}`}>{concept.label}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="signal-lanes" aria-label="Current signals in this brief">
      <div class="signal-lanes-head">
        <span>Signals</span>
        <span>{formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}</span>
      </div>

      {signalRows.map((lane, index) => (
        <article class={`signal-strip ${lane.bandClass}`} style={`--i:${index}; --importance:${lane.importance}; --importance-pct:${lane.importance}%`}>
          <div class="signal-strip-main">
            <strong>{lane.label}</strong>
            <span>{lane.level}</span>
          </div>
          <p>{lane.state}</p>
          <div class="signal-priority" aria-label={`${lane.priorityLabel}: ${lane.importance} out of 100`}>
            <span>{lane.priorityLabel}</span>
            <i><b></b></i>
            <em>{lane.importance}</em>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .signal-insight-map {
    position: relative;
    display: grid;
    grid-template-columns: minmax(220px, .34fr) minmax(0, 1fr);
    gap: clamp(18px, 3vw, 34px);
    margin: clamp(18px, 4vw, 42px) 0 clamp(32px, 6vw, 56px);
    padding: clamp(18px, 3vw, 28px);
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .22);
    border-radius: 18px;
    background: radial-gradient(circle at 76% 18%, rgba(91, 140, 255, .18), transparent 22rem),
      linear-gradient(135deg, rgba(255, 255, 255, .94), rgba(239, 244, 255, .8));
    box-shadow: 0 26px 90px rgba(46, 91, 208, .14), 0 0 0 1px rgba(255, 255, 255, .82) inset;
  }

  .signal-insight-map::before {
    content: "";
    position: absolute;
    inset: 9px;
    border: 1px solid rgba(46, 91, 208, .12);
    border-radius: 12px;
    pointer-events: none;
  }

  .signal-map-copy,
  .signal-map-stage {
    position: relative;
    z-index: 1;
  }

  .signal-map-label,
  .signal-map-copy a,
  .signal-lanes-head,
  .signal-strip-main span,
  .signal-priority {
    font-family: var(--font-label);
    font-weight: 800;
    text-transform: uppercase;
  }

  .signal-map-label {
    margin: 0 0 .62rem;
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .16em;
  }

  .signal-map-copy h2 {
    max-width: 8ch;
    margin-bottom: .32em;
    font-size: clamp(2rem, 4.2vw, 3.8rem);
  }

  .signal-map-copy p:not(.signal-map-label) {
    max-width: 30ch;
    color: #4f5d78;
    font-size: .96rem;
    line-height: 1.48;
  }

  .signal-map-copy a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    margin-top: .4rem;
    padding: 0 1rem;
    border: 1px solid rgba(46, 91, 208, .28);
    border-radius: 999px;
    background: rgba(255, 255, 255, .68);
    color: var(--azure-deep);
    font-size: .72rem;
    letter-spacing: .11em;
    box-shadow: 0 14px 32px rgba(46, 91, 208, .09);
  }

  .signal-map-stage {
    display: grid;
    gap: clamp(10px, 1.6vw, 14px);
  }

  .signal-map-notes {
    display: grid;
    gap: .48rem;
    width: min(320px, 100%);
    margin-top: .72rem;
  }

  .signal-map-notes article {
    padding: .62rem .72rem;
    border: 1px solid rgba(46, 91, 208, .14);
    border-radius: 10px;
    background: rgba(255, 255, 255, .58);
    box-shadow: 0 10px 24px rgba(46, 91, 208, .06);
  }

  .signal-map-notes strong {
    display: block;
    color: var(--azure-deep);
    font-family: var(--font-label);
    font-size: .58rem;
    font-weight: 800;
    letter-spacing: .1em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .signal-map-notes p {
    margin: .26rem 0 0;
    color: #596780;
    font-size: .76rem;
    line-height: 1.28;
  }

  .signal-orbit-card,
  .signal-lanes {
    border: 1px solid rgba(46, 91, 208, .18);
    border-radius: 14px;
    background: rgba(255, 255, 255, .62);
    box-shadow: 0 16px 44px rgba(46, 91, 208, .09);
  }

  .signal-orbit-card {
    min-height: clamp(250px, 26vw, 340px);
    display: grid;
    grid-template-columns: minmax(240px, .92fr) minmax(220px, .82fr);
    align-items: center;
    gap: clamp(14px, 2vw, 22px);
    padding: clamp(14px, 2vw, 20px);
    overflow: hidden;
  }

  .signal-orbit-figure {
    display: grid;
    place-items: center;
  }

  .signal-orbit-card svg {
    width: min(100%, 560px);
    height: auto;
  }

  .signal-orbit-copy {
    display: grid;
    gap: .65rem;
    align-content: center;
  }

  .signal-orbit-label {
    margin: 0;
    color: var(--azure-deep);
    font-family: var(--font-label);
    font-size: .62rem;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .signal-orbit-copy h3 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.45rem);
    line-height: 1.02;
  }

  .signal-orbit-copy p:not(.signal-orbit-label) {
    margin: 0;
    color: #52617c;
    font-size: .92rem;
    line-height: 1.42;
  }

  .signal-concept-list {
    display: flex;
    flex-wrap: wrap;
    gap: .48rem;
    margin-top: .15rem;
  }

  .signal-concept-chip {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 .72rem;
    border: 1px solid rgba(46, 91, 208, .14);
    border-radius: 999px;
    background: rgba(255, 255, 255, .82);
    color: var(--ink);
    font-family: var(--font-label);
    font-size: .62rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .signal-concept-service {
    color: var(--gold-deep);
    border-color: rgba(201, 163, 94, .22);
    background: rgba(255, 248, 230, .92);
  }

  .signal-concept-leadership {
    color: var(--violet-deep);
    border-color: rgba(160, 108, 240, .2);
    background: rgba(247, 241, 255, .94);
  }

  .signal-concept-learning {
    color: var(--indigo-deep);
    border-color: rgba(110, 116, 240, .2);
    background: rgba(241, 242, 255, .94);
  }

  .signal-concept-technology {
    color: var(--azure-deep);
    border-color: rgba(91, 140, 255, .2);
    background: rgba(240, 245, 255, .94);
  }

  .map-frame {
    fill: rgba(248, 251, 255, .72);
    stroke: rgba(46, 91, 208, .2);
  }

  .map-grid {
    fill: none;
    stroke: rgba(46, 91, 208, .07);
    stroke-width: .25;
  }

  .orbit-line {
    fill: none;
    stroke: rgba(46, 91, 208, .36);
    stroke-dasharray: 1.6 2.8;
    animation: trace 12s linear infinite;
  }

  .orbit-b {
    animation-direction: reverse;
    animation-duration: 9s;
  }

  .concept {
    opacity: 0;
    animation: rise .7s ease both;
    animation-delay: calc(var(--i) * 90ms + 180ms);
  }

  .concept line {
    stroke: rgba(46, 91, 208, .16);
    stroke-dasharray: 1 2;
  }

  .concept circle {
    fill: var(--azure);
    stroke: #fff;
    stroke-width: .8;
  }

  .concept-service circle { fill: var(--gold); }
  .concept-leadership circle { fill: var(--violet); }
  .concept-learning circle { fill: var(--indigo); }
  .concept-technology circle { fill: var(--azure-deep); }

  .orbit-node text {
    fill: #24314d;
    font-family: var(--font-label);
    font-size: 2.6px;
    font-weight: 800;
    text-anchor: middle;
  }

  .orbit-node {
    opacity: 0;
    animation: rise .7s ease both;
    animation-delay: calc(var(--i) * 120ms + 80ms);
  }

  .orbit-node circle {
    fill: rgba(157, 184, 255, .7);
    stroke: rgba(46, 91, 208, .36);
    stroke-width: .45;
  }

  .orbit-node.is-primary circle {
    fill: rgba(91, 140, 255, .95);
    stroke: #fff;
    stroke-width: .9;
    animation: pulse 2.8s ease-in-out infinite;
  }

  .core circle {
    fill: url(#core-glow);
    animation: breathe 3.6s ease-in-out infinite;
  }

  .core path:first-of-type {
    fill: rgba(255, 255, 255, .9);
    stroke: rgba(46, 91, 208, .72);
    stroke-width: .55;
  }

  .core path:last-of-type {
    fill: var(--azure-deep);
    opacity: .9;
  }

  .signal-lanes {
    display: grid;
    gap: 6px;
    padding: clamp(10px, 1.3vw, 13px);
    overflow: hidden;
  }

  .signal-lanes-head {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 0 2px 2px;
    color: var(--azure-deep);
    font-size: .66rem;
    letter-spacing: .14em;
  }

  .signal-lanes-head span:last-child {
    color: #6a7893;
    text-align: right;
  }

  .signal-strip {
    --signal-accent: var(--azure);
    --signal-soft: var(--azure-soft);
    --signal-deep: var(--azure-deep);
    --signal-wash: rgba(91, 140, 255, .13);
    --signal-glow: rgba(91, 140, 255, .46);
    position: relative;
    display: grid;
    grid-template-columns: minmax(112px, .38fr) minmax(0, 1fr) minmax(128px, .32fr);
    align-items: center;
    gap: clamp(10px, 2vw, 18px);
    min-height: 54px;
    padding: .58rem .72rem;
    overflow: hidden;
    border: 1px solid rgba(46, 91, 208, .13);
    border-radius: 10px;
    background:
      linear-gradient(90deg, var(--signal-wash), transparent var(--importance-pct)),
      rgba(255, 255, 255, .7);
    box-shadow: 0 10px 24px rgba(46, 91, 208, .07);
    opacity: 0;
    animation: laneReveal .72s ease both;
    animation-delay: calc(var(--i) * 90ms + 280ms);
  }

  .signal-strip::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--signal-accent), var(--signal-deep));
    opacity: .9;
  }

  .signal-strip-main {
    display: grid;
    gap: 2px;
  }

  .signal-strip-main strong {
    color: var(--ink);
    font-family: var(--font-label);
    font-size: .86rem;
    letter-spacing: .01em;
  }

  .signal-strip-main span {
    color: var(--signal-deep);
    font-size: .62rem;
    letter-spacing: .13em;
  }

  .signal-strip p {
    margin: 0;
    color: #4d5a74;
    font-size: .84rem;
    line-height: 1.26;
  }

  .signal-priority {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 5px 8px;
    color: var(--signal-deep);
    font-size: .6rem;
    letter-spacing: .1em;
  }

  .signal-priority i {
    grid-column: 1 / -1;
    position: relative;
    height: 5px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(46, 91, 208, .12);
  }

  .signal-priority b {
    position: absolute;
    inset: 0 auto 0 0;
    width: var(--importance-pct);
    border-radius: inherit;
    background: linear-gradient(90deg, var(--signal-soft), var(--signal-accent), var(--signal-deep));
    box-shadow: 0 0 14px var(--signal-glow);
    transform-origin: left center;
    animation: priorityFill 1.1s cubic-bezier(.2, .7, .2, 1) both;
    animation-delay: calc(var(--i) * 90ms + 440ms);
  }

  .signal-priority em {
    color: var(--ink);
    font-style: normal;
  }

  .signal-band-90 {
    --signal-accent: #2E5BD0;
    --signal-soft: #9DB8FF;
    --signal-deep: #163C9C;
    --signal-wash: rgba(46, 91, 208, .18);
    --signal-glow: rgba(46, 91, 208, .5);
  }

  .signal-band-85 {
    --signal-accent: #5B8CFF;
    --signal-soft: #B9CAFF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(91, 140, 255, .16);
    --signal-glow: rgba(91, 140, 255, .48);
  }

  .signal-band-80 {
    --signal-accent: #6E74F0;
    --signal-soft: #A9AEFF;
    --signal-deep: #3840BD;
    --signal-wash: rgba(110, 116, 240, .15);
    --signal-glow: rgba(110, 116, 240, .44);
  }

  .signal-band-75 {
    --signal-accent: #A06CF0;
    --signal-soft: #C9A8FF;
    --signal-deep: #6C36C2;
    --signal-wash: rgba(160, 108, 240, .14);
    --signal-glow: rgba(160, 108, 240, .42);
  }

  .signal-band-70 {
    --signal-accent: #C9A35E;
    --signal-soft: #E6CB8E;
    --signal-deep: #8C6526;
    --signal-wash: rgba(201, 163, 94, .15);
    --signal-glow: rgba(201, 163, 94, .42);
  }

  .signal-band-65 {
    --signal-accent: #7FA3FF;
    --signal-soft: #C8D6FF;
    --signal-deep: #2E5BD0;
    --signal-wash: rgba(127, 163, 255, .13);
    --signal-glow: rgba(127, 163, 255, .38);
  }

  .signal-band-60 {
    --signal-accent: #7F86E8;
    --signal-soft: #C8CBFF;
    --signal-deep: #4D55B5;
    --signal-wash: rgba(127, 134, 232, .12);
    --signal-glow: rgba(127, 134, 232, .34);
  }

  .signal-band-55 {
    --signal-accent: #8A97B8;
    --signal-soft: #D7DEEF;
    --signal-deep: #52617C;
    --signal-wash: rgba(138, 151, 184, .11);
    --signal-glow: rgba(138, 151, 184, .28);
  }

  @keyframes trace { to { stroke-dashoffset: -40; } }
  @keyframes rise { from { opacity: 0; transform: translateY(2px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes laneReveal { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes priorityFill { from { transform: scaleX(.18); } to { transform: scaleX(1); } }
  @keyframes pulse { 50% { filter: drop-shadow(0 0 3px rgba(91, 140, 255, .7)); } }
  @keyframes breathe { 50% { opacity: .72; } }

  @media (max-width: 1020px) {
    .signal-insight-map,
    .signal-map-stage {
      grid-template-columns: 1fr;
    }

    .signal-map-copy h2 {
      max-width: none;
    }

    .signal-map-notes {
      width: 100%;
    }

    .signal-orbit-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .signal-insight-map {
      padding: 18px 14px;
    }

    .signal-orbit-card {
      min-height: 230px;
    }

    .signal-orbit-card svg {
      width: 122%;
    }

    .signal-lanes-head,
    .signal-strip {
      grid-template-columns: 1fr;
    }

    .signal-lanes-head {
      display: grid;
    }

    .signal-lanes-head span:last-child {
      text-align: left;
    }

    .signal-strip {
      gap: 8px;
      min-height: 0;
    }

    .signal-priority {
      grid-template-columns: auto 1fr auto;
    }

    .signal-priority i {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit-line,
    .concept,
    .orbit-node,
    .orbit-node.is-primary circle,
    .core circle,
    .signal-strip,
    .signal-priority b {
      animation: none;
      opacity: 1;
    }
  }
</style>
