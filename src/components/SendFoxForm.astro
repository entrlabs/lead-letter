---
<form method="post" action="https://sendfox.com/form/3odzjd/1k9o8d" class="sendfox-form">
  <label for="sendfox_form_email" class="sr-only">Email</label>
  <input type="email" id="sendfox_form_email" placeholder="Your email" name="email" required />
  <div class="sendfox-honeypot" aria-hidden="true">
    <input type="text" name="a_password" tabindex="-1" value="" autocomplete="off" />
  </div>
  <button type="submit">Join the list</button>
</form>
<p class="trust-line">No spam. Unsubscribe anytime.</p>

<style>
  .sendfox-honeypot {
    position: absolute;
    left: 0;
    top: 0;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
  }
</style>
