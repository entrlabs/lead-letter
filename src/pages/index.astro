---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SendFoxForm from '../components/SendFoxForm.astro';
import HYOHCompass from '../components/HYOHCompass.astro';
import { formatDate, formatIssue, formatLetterTitle } from '../utils/format';

const allSignals = (await getCollection('signals')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latest = allSignals[0];
const recent = allSignals.slice(1, 5);

function signalUrl(entry: CollectionEntry<'signals'>) {
  const frontmatterSlug = (entry.data as { slug?: string }).slug;
  return `/${frontmatterSlug ?? entry.slug.replace(/^signals-/, '')}/`;
}

function cleanMarkdownLine(value: string) {
  return value
    .replace(/^>\s?/gm, '')
    .replace(/^[-\d.]+\s+/gm, '')
    .replace(/\*\*/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function extractQuestions(body: string, limit = 2) {
  const match = body.match(/## Questions Worth Asking\n([\s\S]*?)(?:\n---|\n## |$)/i);
  if (!match) return [];

  return match[1]
    .split('\n')
    .map((line) => line.trim())
    .filter((line) => /^\d+\.\s+/.test(line))
    .map((line) => cleanMarkdownLine(line))
    .filter(Boolean)
    .slice(0, limit);
}

const latestBody = latest?.body ?? '';
const questionSignals = extractQuestions(latestBody, 2);
const latestTags = new Set(latest?.data.tags ?? []);
const bodySignalText = latestBody.toLowerCase();
const pressureMap = [
  {
    label: 'Education',
    status: latestTags.has('higher-education') || latestTags.has('career-readiness') ? 'Rising' : 'Watching',
    detail: 'proof',
  },
  {
    label: 'Work',
    status: latestTags.has('workplace-learning') || latestTags.has('management') ? 'Strained' : 'Active',
    detail: 'practice',
  },
  {
    label: 'Founders',
    status: latestTags.has('entrepreneurship') ? 'Worth watching' : 'Quiet',
    detail: 'trust',
  },
  {
    label: 'Technology',
    status: bodySignalText.includes('ai') || latestTags.has('ai-literacy') || latestTags.has('ai-governance') ? 'Rising' : 'In view',
    detail: 'judgment',
  },
];

function visualSignalFor(entry: CollectionEntry<'signals'>) {
  const visualSignals: Record<string, {
    signal: string;
    micro: string;
    tension: string;
    move: string;
    question: string;
    feed: string[];
  }> = {
    '2026-w26-make-your-work-easy-to-trust': {
      signal: 'Proof > Promise',
      micro: 'Trust rises when the evidence is easy to see.',
      tension: 'High claims. Thin proof.',
      move: 'Show the work.',
      question: 'What proof travels?',
      feed: ['Proof', 'Trust', 'Evidence', 'Practice', 'Judgment', 'Signal'],
    },
    '2026-w25-build-the-practice-before-raising-the-bar': {
      signal: 'Practice Before Pressure',
      micro: 'Higher standards need places where people can learn judgment.',
      tension: 'Higher bar. Fewer reps.',
      move: 'Build the practice.',
      question: 'Where do people rehearse?',
      feed: ['Practice', 'Standards', 'Feedback', 'Judgment', 'Learning', 'Signal'],
    },
    '2026-w24-good-ideas-still-need-a-plan': {
      signal: 'Ideas Need Conditions',
      micro: 'Useful plans respect cost, trust, and adoption.',
      tension: 'Hype meets constraint.',
      move: 'Check the conditions.',
      question: 'Can people use it well?',
      feed: ['Cost', 'Trust', 'Adoption', 'Resilience', 'Planning', 'Signal'],
    },
    '2026-w23-use-ai-but-keep-your-judgment': {
      signal: 'Speed Needs Judgment',
      micro: 'AI can accelerate work, but responsibility still has to stay visible.',
      tension: 'Fast output. Unclear ownership.',
      move: 'Explain the decision.',
      question: 'Who is responsible?',
      feed: ['AI', 'Judgment', 'Trust', 'Rules', 'Learning', 'Signal'],
    },
  };

  const visualSlug = (entry.data as { slug?: string }).slug ?? entry.slug.replace(/^signals-/, '');
  return visualSignals[visualSlug] ?? {
    signal: formatLetterTitle(entry.data.title).split(':').pop()?.trim() || formatLetterTitle(entry.data.title),
    micro: entry.data.description,
    tension: 'Noise vs. signal',
    move: 'Find the useful pattern.',
    question: questionSignals[0] || 'What changed this week?',
    feed: ['Leadership', 'Service', 'Work', 'Learning', 'Decision', 'Signal'],
  };
}

const visualSignal = latest ? visualSignalFor(latest) : undefined;
const signalFeed = visualSignal ? [...visualSignal.feed, ...visualSignal.feed] : [];
---
<BaseLayout
  title="EntrLabs — The Lead Letter"
  description="Weekly Signals Briefs on leadership, service, and the discipline of helping people rise."
>
  <section class="home-hero reveal">
    <div class="hero-copy">
      <p class="kicker" data-today-label>Today</p>
      <h1>The Lead Letter</h1>
      <p class="positioning">
        Updates each week on leadership, service, work, learning, and the discipline of helping people rise.
      </p>
      <p class="by-joseph">By <a href="https://josephiesue.com" target="_blank" rel="noopener">Joseph E. Iesue</a></p>
      <div class="hero-actions">
        {latest && <a class="primary-action" href={signalUrl(latest)}>Read latest brief</a>}
        <a class="secondary-action" href="/#join">Get future issues</a>
      </div>
    </div>

    {latest && (
      <article class="latest-feature reveal">
        <div class="latest-feature-content">
          <div class="latest-feature-copy">
            <p class="feature-label">Latest Signals Brief</p>
            <h2><a href={signalUrl(latest)}>{formatLetterTitle(latest.data.title)}</a></h2>
            <p>{latest.data.description}</p>
          </div>
          <div class="latest-cube" aria-hidden="true">
            <span class="cube-face cube-top"></span>
            <span class="cube-face cube-left"></span>
            <span class="cube-face cube-right"></span>
            <span class="cube-grid"></span>
          </div>
        </div>
        <div class="feature-meta">
          <span>{formatDate(latest.data.date)}</span>
          <span>{formatIssue(latest.data.issue)}</span>
          <span>6 min read</span>
        </div>
      </article>
    )}
  </section>

  {latest && (
    <section class="signal-board reveal" aria-labelledby="weekly-signal-board">
      <div class="signal-board-stream" aria-hidden="true">
        {signalFeed.map((item) => <span>{item}</span>)}
      </div>

      <div class="signal-board-header">
        <div>
          <p class="signal-board-label">Weekly Signal Board</p>
          <h2 id="weekly-signal-board">What changed this week</h2>
        </div>
        <p>
          A visual translation of the latest brief: one signal, one tension, one move, and one question worth carrying.
        </p>
        <a class="signal-board-link" href={signalUrl(latest)}>Read the full brief</a>
      </div>

      <div class="signal-strip">
        <article class="signal-panel signal-panel-primary">
          <p class="signal-panel-label">Signal</p>
          <h3>{visualSignal?.signal}</h3>
          <p class="signal-micro">{visualSignal?.micro}</p>
        </article>

        <div class="signal-rail" aria-label="Current pressure map">
          {pressureMap.map((item) => (
            <div class="signal-rail-item">
              <span>
                <strong>{item.label}</strong>
                <em>{item.detail}</em>
              </span>
              <b>{item.status}</b>
            </div>
          ))}
        </div>

        <article class="signal-panel leaders-panel">
          <p class="signal-panel-label">Tension</p>
          <p class="signal-panel-main signal-large">{visualSignal?.tension}</p>
        </article>

        <article class="signal-panel watch-panel">
          <p class="signal-panel-label">Move</p>
          <p class="signal-panel-main signal-large">{visualSignal?.move}</p>
        </article>

        <article class="signal-panel question-panel">
          <p class="signal-panel-label">Question</p>
          <p class="signal-panel-main signal-large">{visualSignal?.question}</p>
        </article>
      </div>
    </section>
  )}

  <section class="home-lower reveal">
    <div class="from-archive">
      <div class="section-heading-row">
        <h2>From the Archive</h2>
        <a class="browse-full" href="/archive/">View all briefs</a>
      </div>
      <ul class="archive-preview-list">
        {recent.map((entry) => (
          <li>
            <span class="archive-dot" aria-hidden="true"></span>
            <div class="archive-preview-copy">
              <h3 class="title"><a href={signalUrl(entry)}>{formatLetterTitle(entry.data.title)}</a></h3>
            </div>
            <p class="meta">{formatDate(entry.data.date)}</p>
            <p class="meta">{formatIssue(entry.data.issue)}</p>
            <a class="archive-arrow" href={signalUrl(entry)} aria-label={`Read ${formatLetterTitle(entry.data.title)}`}>→</a>
          </li>
        ))}
      </ul>
    </div>

    <section id="join" class="subscribe-band reveal">
      <div class="subscribe-mark" aria-hidden="true">
        <span class="entr-logo-tile">
          <img src="/assets/entr-icon.svg" alt="" />
        </span>
      </div>
      <div class="subscribe-copy-wrap">
        <p>Build better judgment. Serve with strength.</p>
        <p class="subscribe-copy">A weekly note for founders, educators, managers, and builders who take responsibility seriously.</p>
      </div>
      <SendFoxForm />
    </section>
  </section>

  <HYOHCompass variant="full" />

  <section class="about-strip">
    <p>
      Published by <a href="https://entr.cc/entrlabs" target="_blank" rel="noopener">EntrLabs</a>,
      the research arm of ENTR, this series translates leadership research, service, and systems thinking into practical public notes.
    </p>
    <p>
      Written by <a href="https://josephiesue.com" target="_blank" rel="noopener">Joseph E. Iesue</a>,
      a leadership researcher and practitioner working at the intersection of leadership and service.
    </p>
  </section>
  <script is:inline>
    const todayLabel = document.querySelector('[data-today-label]');
    if (todayLabel) {
      todayLabel.textContent = new Intl.DateTimeFormat('en-US', {
        weekday: 'long',
        month: 'long',
        day: 'numeric',
        year: 'numeric',
      }).format(new Date());
    }
  </script>
</BaseLayout>
