---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SendFoxForm from '../components/SendFoxForm.astro';
import HYOHCompass from '../components/HYOHCompass.astro';
import { toRoman, formatDate } from '../utils/format';

const allLetters = (await getCollection('letters')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latest = allLetters[0];
const recent = allLetters.slice(1, 7);

function letterUrl(entry: CollectionEntry<'letters'>) {
  return `/${entry.slug}/`;
}
---
<BaseLayout
  title="EntrLabs — The Lead Letter"
  description="A weekly letter on leadership, service, and the discipline of helping people rise."
>
  <section class="masthead">
    <div class="rule-double" aria-hidden="true"></div>
    <p class="kicker masthead-kicker">A Publication of EntrLabs</p>
    <h1 class="masthead-title">The Lead Letter</h1>
    <p class="masthead-sub">
      A weekly letter on leadership, service, and the discipline of helping people rise.
      <span class="masthead-byline">By Joseph E. Iesue.</span>
    </p>
    <p class="doctrine"><span>Strength Through Service</span></p>
    <div class="rule-double" aria-hidden="true"></div>
  </section>

  {latest && (
    <section class="home-section">
      <div class="section-label">
        <span class="numeral">I</span>
        <span class="label">The Latest</span>
        <span class="line" aria-hidden="true"></span>
      </div>
      <article class="latest">
        <p class="issue-line">Letter № {toRoman(latest.data.issue)} · {formatDate(latest.data.date)}</p>
        <h2 class="latest-title"><a href={letterUrl(latest)}>{latest.data.title}</a></h2>
        <p class="latest-desc">{latest.data.description}</p>
        <a class="read-link" href={letterUrl(latest)}>Read the letter →</a>
      </article>
    </section>
  )}

  <section id="join" class="subscribe-band">
    <p class="kicker">The Newsletter</p>
    <p class="subscribe-lede">One letter a week. One idea worth keeping. Free.</p>
    <SendFoxForm />
  </section>

  <section class="home-section">
    <div class="section-label">
      <span class="numeral">II</span>
      <span class="label">From the Archive</span>
      <span class="line" aria-hidden="true"></span>
    </div>
    <ul class="preview-list">
      {recent.map((entry) => (
        <li class="preview-row">
          <span class="row-no">№ {toRoman(entry.data.issue)}</span>
          <div class="row-body">
            <a class="row-title" href={letterUrl(entry)}>{entry.data.title}</a>
            <p class="row-desc">{entry.data.description}</p>
            <p class="row-meta">{formatDate(entry.data.date)}</p>
          </div>
        </li>
      ))}
    </ul>
    <a class="read-link browse-link" href="/archive/">Browse the full archive →</a>
  </section>

  <section class="home-section">
    <div class="section-label">
      <span class="numeral">III</span>
      <span class="label">Related Reading</span>
      <span class="line" aria-hidden="true"></span>
    </div>
    <HYOHCompass variant="full" />
  </section>

  <section class="home-section about-strip">
    <div class="section-label">
      <span class="numeral">IV</span>
      <span class="label">The Publication</span>
      <span class="line" aria-hidden="true"></span>
    </div>
    <p>
      The Lead Letter is a weekly publication of
      <a href="https://entr.cc/entrlabs" target="_blank" rel="noopener">EntrLabs</a>,
      a research lab of ENTR, on leadership, service, and the discipline of helping people rise.
    </p>
    <p>
      Written by <a href="https://josephiesue.com" target="_blank" rel="noopener">Joseph E. Iesue</a>,
      a leadership researcher and practitioner. One sharp idea at a time.
    </p>
  </section>
</BaseLayout>
