---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HYOHCompass from '../components/HYOHCompass.astro';
import CopyLinkButton from '../components/CopyLinkButton.astro';
import { toRoman, formatDate } from '../utils/format';

export async function getStaticPaths() {
  const letters = await getCollection('letters');
  return letters.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'letters'>;
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();

const allLetters = (await getCollection('letters')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const idx = allLetters.findIndex((e) => e.slug === entry.slug);
const newer = idx > 0 ? allLetters[idx - 1] : null;
const older = idx < allLetters.length - 1 ? allLetters[idx + 1] : null;

const canonicalUrl = `https://letters.entr.cc/${entry.slug}/`;
---
<BaseLayout title={`${entry.data.title} — The Lead Letter`} description={entry.data.description}>
  <article class="letter-page">
    <header class="letter-header">
      <p class="kicker letter-kicker">
        The Lead Letter · № {toRoman(entry.data.issue)} · {formatDate(entry.data.date)}
      </p>
      <h1 class="letter-title">{entry.data.title}</h1>
      <p class="byline">
        By <a href="https://josephiesue.com" target="_blank" rel="noopener">{entry.data.author}</a>
        <span class="byline-sep">·</span> {entry.data.publication}
      </p>
      <div class="rule-double slim" aria-hidden="true"></div>
    </header>

    <div class="letter-body">
      <Content />
    </div>

    <script>
      const calloutLabels = {
        note: 'Note',
        tip: 'Takeaway',
        quote: 'Signal',
        important: 'Important',
        warning: 'Watchpoint',
      };

      document.querySelectorAll('.letter-body blockquote').forEach((quote) => {
        if (quote.classList.contains('callout')) return;

        const firstParagraph = quote.querySelector('p:first-child');
        const marker = firstParagraph?.textContent?.trim().match(/^\[!(NOTE|TIP|QUOTE|IMPORTANT|WARNING)\]/i);
        if (!firstParagraph || !marker) return;

        const type = marker[1].toLowerCase();
        quote.classList.add('callout', `callout-${type}`);
        firstParagraph.innerHTML = firstParagraph.innerHTML.replace(/^\s*\[!(NOTE|TIP|QUOTE|IMPORTANT|WARNING)\]\s*/i, '');

        const label = document.createElement('div');
        label.className = 'callout-label';
        label.textContent = calloutLabels[type] || 'Note';
        quote.prepend(label);

        if (!firstParagraph.textContent?.trim()) {
          firstParagraph.remove();
        }
      });
    </script>

    <p class="end-mark"><span>— Strength Through Service —</span></p>

    <div class="post-letter-cta">
      <p class="kicker">Pass It On</p>
      <p class="cta-copy">If this letter was useful, it will be useful to someone you lead. Share it — or join the list and get the next one.</p>
      <div class="cta-buttons">
        <a class="btn-join" href="/#join">Join the Lead Letter</a>
        <CopyLinkButton url={canonicalUrl} />
      </div>
    </div>

    <HYOHCompass variant="cta" />

    <nav class="prev-next" aria-label="Letter navigation">
      <div class="pn-cell">
        {older && (
          <>
            <p class="pn-label">Previous Letter</p>
            <a href={`/${older.slug}/`}>{older.data.title}</a>
          </>
        )}
      </div>
      <div class="pn-cell pn-next">
        {newer && (
          <>
            <p class="pn-label">Next Letter</p>
            <a href={`/${newer.slug}/`}>{newer.data.title}</a>
          </>
        )}
      </div>
    </nav>

    <a class="back-to-archive" href="/archive/">← Back to the Archive</a>
  </article>
</BaseLayout>
