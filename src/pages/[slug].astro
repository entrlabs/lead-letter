---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HYOHCompass from '../components/HYOHCompass.astro';
import CopyLinkButton from '../components/CopyLinkButton.astro';
import { formatDate, formatIssue, formatLetterTitle } from '../utils/format';

export async function getStaticPaths() {
  const signals = await getCollection('signals');
  return signals.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'signals'>;
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();

const allSignals = (await getCollection('signals')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const idx = allSignals.findIndex((e) => e.slug === entry.slug);
const newer = idx > 0 ? allSignals[idx - 1] : null;
const older = idx < allSignals.length - 1 ? allSignals[idx + 1] : null;

function signalUrl(e: CollectionEntry<'signals'>) {
  return `/${e.slug}/`;
}

const canonicalUrl = `https://letters.entr.cc${signalUrl(entry)}`;
const displayTitle = formatLetterTitle(entry.data.title);
---
<BaseLayout
  title={`${displayTitle} — The Lead Letter`}
  description={entry.data.description}
  canonicalPath={signalUrl(entry)}
  type="article"
  publishedTime={entry.data.date}
  author={entry.data.author}
>
  <article class="letter-page">
    <p class="kicker letter-kicker">
      Signals Brief · {formatIssue(entry.data.issue)} · {formatDate(entry.data.date)}
    </p>
    <h1>{displayTitle}</h1>
    <p class="byline">
      By <a href="https://josephiesue.com" target="_blank" rel="noopener">{entry.data.author}</a> · {entry.data.publication}
    </p>
    <hr class="hairline" />

    <div class="letter-body">
      <Content />
    </div>

    <p class="end-mark">Strength Through Service</p>

    <div class="post-letter-cta">
      <p>If this brief was useful, it will be useful to someone you lead. Share it — or join the list and get the next one.</p>
      <div class="cta-buttons">
        <a class="btn-join" href="/#join">Get future issues</a>
        <CopyLinkButton url={canonicalUrl} />
      </div>
    </div>

    <HYOHCompass variant="cta" />

    <nav class="prev-next">
      {older ? <a href={signalUrl(older)}>Previous: {formatLetterTitle(older.data.title)}</a> : <span class="empty">Previous</span>}
      {newer ? <a href={signalUrl(newer)}>Next: {formatLetterTitle(newer.data.title)}</a> : <span class="empty">Next</span>}
    </nav>

    <a class="back-to-archive" href="/archive/">Back to Archive</a>
  </article>
  <script>
    const calloutLabels = {
      note: 'Main idea',
      tip: 'Practice',
      quote: 'Signal',
      important: 'Important',
      leaders: 'Leaders',
      warning: 'Watchpoint',
    };

    document.querySelectorAll('.letter-body blockquote').forEach((quote) => {
      if (quote.classList.contains('callout')) return;

      const firstParagraph = quote.querySelector('p:first-child');
      const marker = firstParagraph?.textContent?.trim().match(/^\[!(NOTE|TIP|QUOTE|IMPORTANT|LEADERS|WARNING)\]/i);
      if (!firstParagraph || !marker) return;

      const type = marker[1].toLowerCase();
      quote.classList.add('callout', `callout-${type}`);
      firstParagraph.innerHTML = firstParagraph.innerHTML.replace(/^\s*\[!(NOTE|TIP|QUOTE|IMPORTANT|LEADERS|WARNING)\]\s*/i, '');

      const label = document.createElement('div');
      label.className = 'callout-label';
      label.textContent = calloutLabels[type] || 'Note';
      quote.prepend(label);

      if (!firstParagraph.textContent?.trim()) {
        firstParagraph.remove();
      }
    });
  </script>
</BaseLayout>
