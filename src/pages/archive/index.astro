---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HYOHCompass from '../../components/HYOHCompass.astro';
import { formatDate, formatIssue, formatLetterTitle } from '../../utils/format';

const allSignals = (await getCollection('signals')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = allSignals[0];
const rest = allSignals.slice(1);

function signalUrl(entry: CollectionEntry<'signals'>) {
  return `/${entry.data.slug ?? entry.slug.replace(/^signals-/, '')}/`;
}
---
<BaseLayout title="The Archive — The Lead Letter" description="Every Signal Brief, in order.">
  <div class="archive-page">
    <section class="archive-hero reveal">
      <p class="kicker">Archive</p>
      <h1>All Signal Briefs</h1>
      <p class="archive-count">
        {allSignals.length} brief{allSignals.length === 1 ? '' : 's'} and counting. Published weekly by EntrLabs.
      </p>
    </section>

    {featured && (
      <section class="archive-bento">
        <a class="archive-card archive-card-featured reveal" href={signalUrl(featured)}>
          <p class="archive-row-meta">{formatDate(featured.data.date)} - {formatIssue(featured.data.issue)}</p>
          <h2 class="archive-row-title">{formatLetterTitle(featured.data.title)}</h2>
          <p class="archive-row-desc">{featured.data.description}</p>
        </a>

        {rest.map((entry) => (
          <a class="archive-card reveal" href={signalUrl(entry)}>
            <p class="archive-row-meta">{formatDate(entry.data.date)} - {formatIssue(entry.data.issue)}</p>
            <h2 class="archive-row-title">{formatLetterTitle(entry.data.title)}</h2>
            <p class="archive-row-desc">{entry.data.description}</p>
            {entry.data.tags.length > 0 && (
              <p class="archive-row-tags">{entry.data.tags.slice(0, 3).join(' / ')}</p>
            )}
          </a>
        ))}
      </section>
    )}

    <HYOHCompass variant="quiet" />
  </div>
</BaseLayout>
