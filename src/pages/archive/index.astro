---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HYOHCompass from '../../components/HYOHCompass.astro';
import { toRoman, formatDate } from '../../utils/format';

const allLetters = (await getCollection('letters')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const byYear = new Map<number, CollectionEntry<'letters'>[]>();
for (const entry of allLetters) {
  const year = entry.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(entry);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<BaseLayout title="The Archive — The Lead Letter" description="Every letter, in order.">
  <div class="archive-page">
    <header class="page-header">
      <p class="kicker">The Record</p>
      <h1>The Archive</h1>
      <p class="archive-count">
        {allLetters.length} letter{allLetters.length === 1 ? '' : 's'} and counting. Published weekly.
      </p>
      <div class="rule-double slim" aria-hidden="true"></div>
    </header>

    {years.map((year) => (
      <section class="archive-year-block">
        <div class="section-label">
          <span class="numeral year">{year}</span>
          <span class="line" aria-hidden="true"></span>
        </div>
        {byYear.get(year)!.map((entry) => (
          <a class="ledger-row" href={`/${entry.slug}/`}>
            <span class="ledger-no">№ {toRoman(entry.data.issue)}</span>
            <span class="ledger-main">
              <span class="ledger-title">{entry.data.title}</span>
              <span class="ledger-desc">{entry.data.description}</span>
              {entry.data.tags.length > 0 && (
                <span class="ledger-tags">{entry.data.tags.join(' · ')}</span>
              )}
            </span>
            <span class="ledger-date">{formatDate(entry.data.date)}</span>
          </a>
        ))}
      </section>
    ))}

    <HYOHCompass variant="quiet" />
  </div>
</BaseLayout>
